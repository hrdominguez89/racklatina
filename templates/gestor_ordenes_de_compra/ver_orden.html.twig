{% extends 'base.html.twig' %}
{% block title %}
    Orden de compra en detalle.
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('Datatables/datatables.min.css') }}">
    
    <style media="print">
    @page {
        size: A4 landscape;
        margin: 10mm;
    }

    body {
        font-size: 10pt;
    }

    table {
        width: 100% !important;
        table-layout: fixed;
        border-collapse: collapse;
    }

    th, td {
        font-size: 9pt;
        padding: 4px;
        word-wrap: break-word;
        border: 1px solid #000;
    }

    th {
        background-color: #f2f2f2;
        font-weight: bold;
    }

    /* Evitar corte en filas */
    tr, td, th {
        page-break-inside: avoid !important;
    }

    /* Ocultar elementos innecesarios */
    .dataTables_length,
    .dataTables_filter,
    .dataTables_info,
    .dataTables_paginate,
    .dt-buttons,
    .btn,
    .breadcrumb,
    .navbar,
    .d-print-none {
        display: none !important;
    }
</style>
    {% endblock %}
    {% block body %}
        <div class="container-fluid">
            <!-- start page title -->
            <div class="row">
                <div class="col-12">
                    <div class="page-title-box d-sm-flex align-items-center justify-content-between bg-galaxy-transparent">
                        <div class="page-title-right">
                            <ol class="breadcrumb m-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_home') }}">
                                        Mi portal
                                    </a>
                                </li>
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_gestor_ordenes_de_compra', {status:app.request.get('status') ? app.request.get('status'):'Todas',search: app.request.get('search'),searchType: app.request.get('searchType'),'searchArticulo':app.request.get('searchArticulo')??''}) }}">
                                        Informes de Órdenes de Compra
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    Detalle
                                </li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
            
        <div class="row d-print-none">
    <div class="col-12 text-end">
        <button onclick="window.print()" class="btn btn-outline-primary">Imprimir</button>
    </div>
</div>
            <div class="row mt-4">
                <div class="col-12">
                    <h4>
                        Informacion de la orden de compra (nro cliente) #
                        {{ orden_de_compra.OrdenCompraCliente }}
                    </h4>
                    <p>
                        <strong>
                            Nro. de pedido:
                        </strong>
                        {{ orden_de_compra.numero }}
                    </p>
                    <p>
                        <strong>
                            Informacion de la orden de compra:
                        </strong>
                        <table class="table table-striped table-sm">
                            <tbody>
                                <tr>
                                    <td>Cliente</td>
                                    <td>{{ orden_de_compra.razonsocial }}</td>
                                    <td colspan="2"></td>
                                </tr>
                                <tr>
                                    <td>
                                        Orden de compra del cliente
                                    </td>
                                    <td>
                                        {{ orden_de_compra.ordencompracliente }}
                                    </td>
                                    <td>
                                        Fecha de OC
                                    </td>
                                    <td>
                                        {{ orden_de_compra.fechaoc ?? '' }}
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        Lugar de entrega
                                    </td>
                                    <td>
                                        {{ orden_de_compra.lugar }}
                                    </td>
                                    <td>
                                        Transporte
                                    </td>
                                    <td>
                                        {{ orden_de_compra.transporte }}
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        Forma de pago
                                    </td>
                                    <td>
                                        {{ orden_de_compra.pago }}
                                    </td>
                                    <td>
                                        Cobrador
                                    </td>
                                    <td>
                                        {{ orden_de_compra.cobrador }}
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </p>
                </div>
            </div>
            <div class="row mt-4">
                <div class="col-12">
                    <h5 class="mt-4">
                        Ítems de la orden de compra
                    </h5>
                    <table id="tabla-detalle"  class="table table-bordered table-striped table-sm">
                        <thead>
                        <tr>
                            <th class="text-center">Artículo</th>
                            <th class="text-center">Detalle</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Cant.<br> asignada</th>
                            <th class="text-center">Cant.<br> original</th>
                            <th class="text-center">Cant.<br> pendiente</th>
                            <th class="text-center">Cant.<br> entregada</th>
                            <th class="text-center">Fecha de<br> entrega</th>
                            <th class="text-center">Fecha<br> emision remitos</th>
                            <th class="text-center">Fecha de<br> entrega remitos</th>
                            <th class="text-center">Precio<br> USD</th>
                            <th class="text-center">Importe<br> USD</th>
                            <th class="text-center">Remito</th>
                            <th class="text-center">Factura</th>
                        </tr>
                    </thead>
                        <tbody>
                            {% for item in ordenes_de_compra %}
                            {% if item.cantidadoriginal > 0 %}
                                <tr class="align-middle">
                                    <td>
                                        {{ item.articulo }}
                                    </td>
                                    <td>
                                        {{ item.detalle }}
                                    </td>
                                    <td>
                                        {% if item.preparado > 0 and item.estado == "Pendiente" %}
                                            {{ item.preparado }} preparado
                                        {% else %}
                                            {{ item.fechaentregarem ? 'Entregado' : item.estado }}
                                        {% endif %}
                                        {% if item.subdividido %}
                                            <br><button type="button" class="btn btn-sm btn-outline-info ver-desglose-btn mt-1" data-articulo="{{ item.articulo }}">
                                                <i class="ri-git-branch-line"></i> {{ item.lineas|length }} líneas
                                            </button>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">{{ item.cantidadasignada }}</td>
                                    <td class="text-center">{{ item.cantidadoriginal }}</td>
                                    <td class="text-center">{{ item.cantidadPendiente }}</td>
                                    <td class="text-center">{{ item.cantEnt }}</td>
                                    {% set fecha_visible = item.fechaentrega ? item.fechaentrega : item.fechaEstimada ?? null %}
                                    {% set hoy = 'now'|date('Y-m-d') %}
                                    {% if fecha_visible %}
                                        {% set fecha = fecha_visible|split('/') %}
                                        {% set fecha_ordenada = fecha[2] ~ '/' ~ fecha[1] ~ '/' ~ fecha[0] %}
                                        {% set fecha_iso = fecha[2] ~ '-' ~ fecha[1] ~ '-' ~ fecha[0] %}
                                        {% if fecha_iso < hoy and item.estado != "Remitido" %}
                                            <td class="bg-danger text-white" data-order="{{ fecha_ordenada }}">
                                                <i class="ri-alert-line"></i> 
                                                {{ fecha_visible }}
                                                  <button type="button" class="btn btn-sm btn-primary" name="Contactar-por-vencimiento">
                                                    <i class="ri-mail-line"></i> Contactar
                                                </button>
                                            </td>
                                        {% else %}
                                            <td data-order="{{ fecha_ordenada }}">
                                                {{ fecha_visible }}
                                            </td>
                                        {% endif %}
                                    {% else %}
                                        <td data-order="9999-12-31" class="bg-primary text-center"></td>
                                    {% endif %}
                                    {% set fecha_visible = item.fecharemitos ? item.fecharemitos : null  %}
                                    {% if fecha_visible %}
                                        {% set fecha = fecha_visible|split('/') %}
                                        {% set fecha_ordenada = fecha[2] ~ '/' ~ fecha[1] ~ '/' ~ fecha[0] %}
                                        <td data-order="{{ fecha_ordenada }}"> {{fecha_visible}}</td>
                                    {% else %}
                                        <td data-order="9999-12-31"></td>
                                    {% endif %}
                                     {% set fecha_visible = item.fechaentregarem ? item.fechaentregarem : null  %}
                                    {% if fecha_visible %}
                                        {% set fecha = fecha_visible|split('/') %}
                                        {% set fecha_ordenada = fecha[2] ~ '/' ~ fecha[1] ~ '/' ~ fecha[0] %}
                                        <td data-order="{{ fecha_ordenada }}"> {{fecha_visible}}</td>
                                    {% else %}
                                        <td data-order="9999-12-31"></td>
                                    {% endif %}
                                    <td>
                                        $&nbsp;{{ item.precioDolar|number_format(2, ',', '.') }}
                                    </td>
                                    <td>
                                        $&nbsp;{{ item.importeDolar|number_format(2, ',', '.') }}
                                    </td>
                                    <td>
                                        {% if item.remitos %}
                                            {% for remito in item.remitos|split(' - ') %}
                                                <a href="#" class="remito-link" data-remito="{{ remito|split(' ')[0] }}">
                                                    {{ (remito|replace({' ': '&nbsp;'}))|raw }}
                                                </a>
                                                <br>
                                                {% endfor %}
                                            {% else %}
                                                -
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if item.facturas %}
                                                {% for factura in item.facturas|split(' - ') %}
                                                    <a href="#" class="factura-link" data-factura="{{ factura|split(' ')[0] }}">
                                                        {{ (factura|replace({' ': '&nbsp;'}))|raw }}
                                                    </a>
                                                    <br>
                                                    {% endfor %}
                                                {% else %}
                                                    -
                                                {% endif %}
                                            </td>
                                        </tr>
                                        {% endif %}
                                    {% endfor %}
                                
                                </tbody>
                            </table>
                            {% for item in ordenes_de_compra %}
                                {% if item.subdividido %}
                                <div class="d-none" id="desglose-{{ item.articulo }}">
                                    <p class="mb-2">
                                        <strong>{{ item.articulo }}</strong> – {{ item.detalle }}<br>
                                        <span class="text-muted">Este artículo está dividido en {{ item.lineas|length }} líneas internas en Calypso.</span>
                                    </p>
                                    <table class="table table-sm table-bordered table-striped">
                                        <thead>
                                            <tr>
                                                <th>Cant. original</th>
                                                <th>Cant. asignada</th>
                                                <th>Cant. pendiente</th>
                                                <th>Cant. entregada</th>
                                                <th>Estado</th>
                                                <th>Fecha entrega</th>
                                                <th>Remito</th>
                                                <th>Factura</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for linea in item.lineas %}
                                            <tr>
                                                <td>{{ linea.cantidadoriginal }}</td>
                                                <td>{{ linea.cantidadasignada }}</td>
                                                <td>{{ linea.cantidadPendiente }}</td>
                                                <td>{{ linea.cantEnt }}</td>
                                                <td>{{ linea.fechaentregarem ? 'Entregado' : linea.estado }}</td>
                                                <td>{{ linea.fechaentrega ?? linea.fechaEstimada ?? '' }}</td>
                                                <td>{{ linea.remitos ?? '-' }}</td>
                                                <td>{{ linea.facturas ?? '-' }}</td>
                                            </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="row mt-4">
                        <div class="col-12 text-end">
                            <a class="btn btn-secondary"
                            href="{{ path('app_gestor_ordenes_de_compra',
                            {status:app.request.get('status') ? app.request.get('status'):'Todas',search: app.request.get('search'),searchType: app.request.get('searchType'),'searchArticulo':app.request.get('searchArticulo')??''}) }}">
                                Volver
                            </a>
                        </div>
                    </div>
                </div>
                <!-- Modal Container para Remitos -->
                <div class="modal fade" id="modalRemito" tabindex="-1" aria-labelledby="modalRemitoLabel" aria-hidden="true">
                    <div class="modal-dialog modal-xl">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="modalRemitoLabel">
                                    Detalle de Remitos
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body" id="modalRemitoBody">
                                <!-- El contenido se cargará aquí via AJAX -->
                                <div class="text-center">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">
                                            Cargando...
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                    Cerrar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Modal Container para Facturas -->
                <div class="modal fade" id="modalFactura" tabindex="-1" aria-labelledby="modalFacturaLabel" aria-hidden="true">
                    <div class="modal-dialog modal-xl">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="modalFacturaLabel">
                                    Detalle de Facturas
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body" id="modalFacturaBody">
                                <!-- El contenido se cargará aquí via AJAX -->
                                <div class="text-center">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">
                                            Cargando...
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                    Cerrar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Modal Desglose de líneas -->
                <div class="modal fade" id="modalDesglose" tabindex="-1" aria-labelledby="modalDesgloseLabel" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="modalDesgloseLabel">Desglose de líneas del artículo</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body" id="modalDesgloseBody"></div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                            </div>
                        </div>
                    </div>
                </div>
            {% endblock %}
            {% block javascripts %}
                {{ parent() }}
                <script src="{{ asset('js/jquery-3.7.1.min.js') }}"></script>
                <script src="{{ asset('Datatables/datatables.min.js') }}"></script>
                <script>
        $(document).ready(function() {
            // Manejar clicks en enlaces de remitos
            $('.remito-link').on('click', function(e) {
                e.preventDefault();
                
                const numeroRemito = $(this).data('remito');
                const modalRemitoBody = $('#modalRemitoBody');
                console.log("Este es mi numero de remito"+numeroRemito );
                // Mostrar spinner
                modalRemitoBody.html(`
                    <div class="text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                    </div>
                `);
                
                // Mostrar modal
                const modal = new bootstrap.Modal(document.getElementById('modalRemito'));
                modal.show();
                
                // Cargar contenido via AJAX
                $.ajax({
                    url: "{{ path('app_remito_show_int',{'numero':'PLACEHOLDER'}) }}".replace('PLACEHOLDER', numeroRemito),
                    type: 'GET',
                    success: function(response) {
                        modalRemitoBody.html(response);
                    },
                    error: function() {
                        modalRemitoBody.html('<div class="alert alert-danger">Error al cargar el remito</div>');
                    }
                });
            });
            
            // Manejar clicks en enlaces de facturas
            $('.factura-link').on('click', function(e) {
                e.preventDefault();
                
                const numeroFactura = $(this).data('factura');
                const modalFacturaBody = $('#modalFacturaBody');
                
                // Mostrar spinner
                modalFacturaBody.html(`
                    <div class="text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                    </div>
                `);
                
                // Mostrar modal
                const modal = new bootstrap.Modal(document.getElementById('modalFactura'));
                modal.show();
                
                // Cargar contenido via AJAX
                $.ajax({
                    url: "{{ path('app_factura_show_int',{'numero':'PLACEHOLDER'}) }}".replace('PLACEHOLDER', numeroFactura),
                    type: 'GET',
                    success: function(response) {
                        modalFacturaBody.html(response);
                    },
                    error: function() {
                        modalFacturaBody.html('<div class="alert alert-danger">Error al cargar la factura</div>');
                    }
                });
            });

            $(document).on('click', '.ver-desglose-btn', function() {
                const articulo = $(this).data('articulo');
                const sourceEl = document.getElementById('desglose-' + articulo);
                if (!sourceEl) return;
                $('#modalDesgloseBody').html(sourceEl.innerHTML);
                const modal = new bootstrap.Modal(document.getElementById('modalDesglose'));
                modal.show();
            });

            $('#tabla-detalle').DataTable({
                scrollX: true,
                autoWidth: false,
                language: {
                    url: esDatatable
                },
                stateSave: true,
                dom: 'Bfrtip',
                buttons: [
                    'colvis',
                    {
                        extend: 'excelHtml5',
                        title: 'Orden de compra nro {{ orden_de_compra.OrdenCompraCliente }} pedido nro {{orden_de_compra.numero}} razon social {{orden_de_compra.razonsocial}}',
                        filename: 'Orden_de_compra_nro_{{ orden_de_compra.OrdenCompraCliente }}_pedido_nro_{{orden_de_compra.numero}}'
                    }
                ],
                dom: "<'row mb-3'<'col-sm-12 col-md-4'l><'col-sm-12 col-md-4 text-center'B><'col-sm-12 col-md-4'f>>" +
                "<'row'<'col-sm-12'tr>>" +
                "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>",
                colReorder: true
            });
        });
    </script>
    {% endblock %}