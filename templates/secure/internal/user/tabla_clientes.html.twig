<table id="tabla-usuarios" class="table table-sm table-striped table-bordered align-middle">
    <thead style="color: #000;">
        <tr>
            <th class="text-center" style="width: 50px;">ID</th>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Email</th>
            <th>Celular</th>
            <th>Empresa</th>
            <th>Cargo</th>
            <th>Sector</th>
            <th>Segmento</th>
            <th>País</th>
            <th>Provincia</th>
            <th class="text-center">DNI</th>
            <th class="text-center">Roles</th>
            <th class="text-center no-export" style="width: 120px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        {% for user in clientes %}
            <tr>
                <td class="text-center fw-semibold text-muted">{{ user.id }}</td>
                <td>{{ user.firstName }}</td>
                <td>{{ user.lastName }}</td>
                <td>{{ user.email ?? '' }}</td>
                <td class="text-nowrap">{{ user.externalUserData ? user.externalUserData.phoneNumber : '' }}</td>
                <td>{{ user.externalUserData ? user.externalUserData.companyName : '' }}</td>
                <td>{{ user.externalUserData ? user.externalUserData.jobTitle : '' }}</td>
                <td>{{ user.externalUserData and user.externalUserData.sector ? user.externalUserData.sector.name : '' }}</td>
                <td>{{ user.externalUserData ? user.externalUserData.segmento : '' }}</td>
                <td>{{ user.externalUserData ? user.externalUserData.pais : '' }}</td>
                <td>{{ user.externalUserData ? user.externalUserData.provincia : '' }}</td>
                <td class="text-center text-nowrap">{{ user.nationalIdNumber }}</td>
                <td class="text-center">
                    {% for rol in user.getRoles %}
                        <span class="badge text-bg-secondary">{{ rol|replace({'ROLE_': ''})|replace({'_': ' '})|title }}</span>
                    {% endfor %}
                </td>
                <td class="text-center no-export">
                    <div class="btn-group btn-group-sm" role="group">
                        <button onclick="modalVer({{ user.id }})" class="btn btn-secondary" title="Ver usuario"><i class="ri-eye-fill"></i></button>
                        <button onclick="modalEditar({{ user.id }})" class="btn btn-warning" title="Editar usuario"><i class="ri-edit-2-fill"></i></button>
                        <button onclick="EliminarUsuario({{ user.id }})" class="btn btn-danger" title="Eliminar usuario"><i class="ri-delete-bin-6-fill"></i></button>
                    </div>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
