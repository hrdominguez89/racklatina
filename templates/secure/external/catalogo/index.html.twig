{% extends 'base_catalogo.html.twig' %}

{% block title %}Catálogo de Productos{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item active">Catálogo</li>
    </ol>
{% endblock %}

{% block stylesheets %}
<style>
.rkl-search-input {
    height: 44px;
    border-radius: 50px !important;
    border: 1px solid #e2e2e2;
    padding-left: 2.8rem;
    font-size: .9rem;
    background: #f8f9fa;
    transition: border-color .2s, background .2s;
}
.rkl-search-input:focus {
    border-color: #bbb; background: #fff; box-shadow: none;
}
.rkl-search-icon {
    left: 14px; top: 50%; transform: translateY(-50%);
    font-size: 1.05rem; color: #aaa; pointer-events: none;
}
.rkl-section-label { font-size: .82rem; font-weight: 600; color: #888; letter-spacing: .2px; }
.rkl-section-link {
    font-size: .78rem; font-weight: 600; color: var(--rkl-primary);
    text-decoration: none; letter-spacing: .3px; text-transform: uppercase;
}
.rkl-section-link:hover { color: var(--rkl-primary-dark); }

.rkl-cat-card {
    position: relative; border-radius: 10px; overflow: hidden;
    min-height: 200px; cursor: pointer; display: block;
    text-decoration: none !important;
    transition: transform .18s, box-shadow .18s;
}
.rkl-cat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.22); }
.rkl-cat-bg {
    position: absolute; inset: 0;
    background-image: url('{{ asset('images/categories_ph.jpg') }}');
    background-size: cover; background-position: center;
    background-color: #2c3e50;
}
.rkl-cat-overlay { position: absolute; inset: 0; background: rgba(20, 28, 38, .62); }
.rkl-cat-body {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; text-align: center;
    height: 100%; min-height: 200px; padding: 1rem;
}
.rkl-cat-name {
    font-size: .9rem; font-weight: 700; color: #fff;
    line-height: 1.35; margin: 0;
    text-shadow: 0 1px 4px rgba(0,0,0,.4);
}

.rkl-prod-card {
    background: #fff; border: 1px solid #ebebeb; border-radius: 10px; overflow: hidden;
    height: 100%; display: flex; flex-direction: column;
    transition: box-shadow .18s, transform .18s;
}
.rkl-prod-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,.1); transform: translateY(-2px); }
.rkl-prod-img-wrap {
    position: relative; background: #f5f5f5; height: 160px;
    display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.rkl-prod-img-wrap img { max-height: 140px; max-width: 100%; object-fit: contain; padding: .75rem; }
.rkl-prod-badge {
    position: absolute; top: 8px; left: 8px;
    background: #1a1a1a; color: #fff;
    border-radius: 50px; font-size: .68rem; font-weight: 600;
    padding: .18rem .6rem; letter-spacing: .2px;
}
.rkl-prod-body { padding: .85rem .9rem 1rem; display: flex; flex-direction: column; flex: 1; }
.rkl-prod-name {
    font-size: .82rem; font-weight: 700; color: #1a1a1a; line-height: 1.35; margin-bottom: .25rem;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.rkl-prod-sub {
    font-size: .72rem; color: #999; margin-bottom: .75rem;
    display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;
}
.rkl-btn-agregar {
    display: block; width: 100%; text-align: center;
    border: 1.5px solid #c8c5a0; background: #fff; color: #7a7300;
    border-radius: 6px; font-size: .7rem; font-weight: 700; letter-spacing: .8px; text-transform: uppercase;
    padding: .5rem .5rem; transition: background .15s, color .15s, border-color .15s; cursor: pointer;
}
.rkl-btn-agregar:hover { background: var(--rkl-primary); color: #fff; border-color: var(--rkl-primary); }
</style>
{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:#1a1a1a;">Productos</h4>
    {% if app.user %}
    <button type="button"
            class="btn btn-sm fw-semibold d-none d-md-inline-flex align-items-center gap-1"
            style="background:var(--rkl-primary);color:#fff;border:none;padding:.4rem 1.2rem;border-radius:6px;"
            data-bs-toggle="modal" data-bs-target="#modalCrearProyecto">
        <i class="ri-add-line"></i> Nuevo Proyecto
    </button>
    {% endif %}
</div>

{# Buscador #}
<div class="mb-5">
    <form action="{{ path('app_catalogo_lista') }}" method="GET">
        <div class="position-relative">
            <i class="ri-search-line position-absolute rkl-search-icon"></i>
            <input type="text" name="q"
                   class="form-control rkl-search-input"
                   placeholder="Buscá un producto"
                   value="{{ app.request.query.get('q') ?? '' }}">
        </div>
    </form>
</div>

{# Categorías #}
<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="rkl-section-label">Seleccioná una categoría</span>
        <a href="{{ path('app_catalogo_lista') }}" class="rkl-section-link">Ver más</a>
    </div>
    <div class="row g-2 g-md-3">
        {% for categoria in categorias %}
        <div class="col-6 col-md-3">
            <a href="{{ path('app_catalogo_lista', {categoria: categoria}) }}" class="rkl-cat-card">
                <div class="rkl-cat-bg c{{ loop.index0 % 8 }}"></div>
                <div class="rkl-cat-overlay"></div>
                <div class="rkl-cat-body">
                    <p class="rkl-cat-name">{{ categoria }}</p>
                </div>
            </a>
        </div>
        {% else %}
        <div class="col-12"><p class="text-muted small">No hay categorías disponibles todavía.</p></div>
        {% endfor %}
    </div>
</div>

{# Productos más recomendados #}
{% if recomendados is not empty %}
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="rkl-section-label">Productos más recomendados</span>
        <a href="{{ path('app_catalogo_lista') }}" class="rkl-section-link">Ver más</a>
    </div>
    <div class="row g-3">
        {% for articulo in recomendados %}
        <div class="col-6 col-md-3">
            <div class="rkl-prod-card">
                <div class="rkl-prod-img-wrap">
                    {% if articulo.imagen %}
                    <img src="{{ articulo.imagen }}" alt="{{ articulo.nombreDisplay }}"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                    <div style="display:none;width:100%;height:100%;align-items:center;justify-content:center;">
                        <i class="ri-image-line fs-2 text-muted"></i>
                    </div>
                    {% else %}
                    <i class="ri-image-line fs-2 text-muted"></i>
                    {% endif %}
                    <span class="rkl-prod-badge">En Stock</span>
                </div>
                <div class="rkl-prod-body">
                    <a href="{{ path('app_catalogo_detalle', {codigo: articulo.codigoCalipso}) }}"
                       class="text-decoration-none"
                       onclick="RKL.clarity('event','producto_click');RKL.clarity('set','producto_clickeado','{{ articulo.codigoCalipso|e('html_attr') }}');">
                        <p class="rkl-prod-name">{{ articulo.nombreDisplay }}</p>
                    </a>
                    {% if articulo.subcategoriaAdvisor %}
                    <p class="rkl-prod-sub">{{ articulo.subcategoriaAdvisor }}</p>
                    {% elseif articulo.descripcion %}
                    <p class="rkl-prod-sub">{{ articulo.descripcion }}</p>
                    {% endif %}
                    <div class="mt-auto">
                        {% if app.user %}
                        <button type="button"
                                class="rkl-btn-agregar btn-agregar-proyecto"
                                data-articulo-codigo="{{ articulo.codigoCalipso }}"
                                data-articulo-nombre="{{ articulo.nombreDisplay|e('html_attr') }}">
                            Agregar a Proyecto
                        </button>
                        {% else %}
                        <a href="{{ path('app_login') }}" class="rkl-btn-agregar" style="display:block;text-align:center;">
                            Iniciá sesión
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# Modal Agregar a Proyecto #}
<div class="modal fade" id="modalAgregarProyecto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:12px;overflow:hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Agregar a Proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3" id="modal-articulo-nombre"></p>
                <div id="modal-sin-proyectos" style="display:none;" class="text-center py-3">
                    <i class="ri-folder-line fs-1 text-muted d-block mb-2"></i>
                    <p class="text-muted mb-3">No tenés proyectos para esta empresa.</p>
                    <a href="{{ path('app_proyectos_index') }}" class="btn fw-semibold px-4"
                       style="background-color:var(--rkl-primary);color:#fff;border:none;">
                        Ir a Proyectos
                    </a>
                </div>
                <div id="modal-con-proyectos">
                    <label class="form-label fw-semibold">Proyecto:</label>
                    <select class="form-select mb-3" id="select-proyecto"><option>Cargando…</option></select>
                    <label class="form-label fw-semibold">Cantidad:</label>
                    <div class="input-group" style="max-width:140px;">
                        <button class="btn btn-outline-secondary" type="button" id="btn-menos">−</button>
                        <input type="number" class="form-control text-center" id="input-cantidad" value="1" min="1" max="999">
                        <button class="btn btn-outline-secondary" type="button" id="btn-mas">+</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light fw-semibold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn fw-semibold px-4" id="btn-confirmar-agregar"
                        style="background-color:var(--rkl-primary);color:#fff;border:none;">Agregar</button>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block extra_js %}
<script>
(function() {
    let articuloCodigoActual = null;
    let articuloNombreActual = null;

    async function agregarArticulo(proyectoId, articuloCodigo, cantidad, btnOrigen) {
        if (btnOrigen) btnOrigen.disabled = true;
        const fd = new FormData();
        fd.append('articulo_codigo', articuloCodigo);
        fd.append('cantidad', cantidad || 1);
        try {
            const res  = await fetch(`/secure/proyectos/${proyectoId}/agregar-articulo`, { method: 'POST', body: fd });
            const data = await res.json();
            if (data.success) {
                RKL.clarity('event', 'producto_agregado');
                RKL.toast(data.mensaje, 'success');
            } else {
                RKL.toast(data.error || 'Error al agregar', 'danger');
            }
        } catch (e) {
            RKL.toast('Error de red: ' + e.message, 'danger');
        } finally {
            if (btnOrigen) btnOrigen.disabled = false;
        }
    }

    async function cargarProyectosEnModal() {
        const select             = document.getElementById('select-proyecto');
        const cuerpoSinProyectos = document.getElementById('modal-sin-proyectos');
        const cuerpoConProyectos = document.getElementById('modal-con-proyectos');
        const btnConfirmar       = document.getElementById('btn-confirmar-agregar');
        if (select) select.innerHTML = '<option>Cargando…</option>';
        try {
            const proyectos = await fetch('/secure/proyectos/mis-proyectos-json').then(r => r.json());
            if (proyectos.length === 0) {
                if (cuerpoSinProyectos) cuerpoSinProyectos.style.display = '';
                if (cuerpoConProyectos) cuerpoConProyectos.style.display = 'none';
                if (btnConfirmar)       btnConfirmar.style.display       = 'none';
            } else {
                if (cuerpoSinProyectos) cuerpoSinProyectos.style.display = 'none';
                if (cuerpoConProyectos) cuerpoConProyectos.style.display = '';
                if (btnConfirmar)       btnConfirmar.style.display       = '';
                if (select) select.innerHTML = proyectos.map(p =>
                    `<option value="${p.id}">${p.nombre} (${p.cantidad} items)</option>`
                ).join('');
            }
        } catch (e) {
            if (select) select.innerHTML = '<option>Error al cargar</option>';
        }
    }

    document.querySelectorAll('.btn-agregar-proyecto').forEach(btn => {
        btn.addEventListener('click', function () {
            articuloCodigoActual = this.dataset.articuloCodigo;
            articuloNombreActual = this.dataset.articuloNombre;
            if (RKL.proyectoActivo) {
                agregarArticulo(RKL.proyectoActivo.id, articuloCodigoActual, 1, this);
                return;
            }
            const el = document.getElementById('modal-articulo-nombre');
            if (el) el.textContent = articuloNombreActual;
            cargarProyectosEnModal();
            new bootstrap.Modal(document.getElementById('modalAgregarProyecto')).show();
        });
    });

    document.getElementById('btn-confirmar-agregar')?.addEventListener('click', async function () {
        const proyectoId = document.getElementById('select-proyecto')?.value;
        const cantidad   = document.getElementById('input-cantidad')?.value || 1;
        if (!proyectoId || !articuloCodigoActual) return;
        this.disabled    = true;
        this.textContent = 'Agregando…';
        bootstrap.Modal.getInstance(document.getElementById('modalAgregarProyecto')).hide();
        await agregarArticulo(proyectoId, articuloCodigoActual, cantidad);
        this.disabled    = false;
        this.textContent = 'Agregar';
    });

    document.getElementById('btn-menos')?.addEventListener('click', () => {
        const inp = document.getElementById('input-cantidad');
        if (inp && parseInt(inp.value) > 1) inp.value = parseInt(inp.value) - 1;
    });
    document.getElementById('btn-mas')?.addEventListener('click', () => {
        const inp = document.getElementById('input-cantidad');
        if (inp && parseInt(inp.value) < 999) inp.value = parseInt(inp.value) + 1;
    });
})();
</script>
{% endblock extra_js %}
