{# Partial: card de artículo (usado en lista e index) #}
{# Variables: articulo, proyectos (opcional), vista (opcional: 'grid'|'list') #}

{% set vista = vista ?? 'grid' %}
{% set proyectos = proyectos ?? [] %}

{% if vista == 'list' %}
{# ---- VISTA LISTA (horizontal) ---- #}
<div class="card border-0 shadow-sm mb-3 catalogo-card-list">
    <div class="card-body p-3">
        <div class="row align-items-center g-3">
            <div class="col-auto">
                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                     style="width:80px;height:80px;overflow:hidden;">
                    {% if articulo.imagen %}
                    <img src="{{ articulo.imagen }}" alt="{{ articulo.nombreDisplay }}"
                         class="img-fluid p-1" style="max-height:80px;object-fit:contain;"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                    <div style="display:none" class="w-100 h-100 align-items-center justify-content-center">
                        <i class="ri-image-line fs-2 text-muted"></i>
                    </div>
                    {% else %}
                    <i class="ri-image-line fs-2 text-muted"></i>
                    {% endif %}
                </div>
            </div>
            <div class="col">
                <a href="{{ path('app_catalogo_detalle', {codigo: articulo.codigoCalipso}) }}" class="text-decoration-none text-dark"
                   onclick="RKL.clarity('event','producto_click');RKL.clarity('set','producto_clickeado','{{ articulo.codigoCalipso|e('html_attr') }}');">
                    <h6 class="mb-1 fw-semibold">{{ articulo.nombreDisplay }}</h6>
                </a>
                {% if articulo.codigoRockwell %}
                <small class="text-muted d-block">Cód: {{ articulo.codigoRockwell }}</small>
                {% endif %}
                {% if articulo.subcategoriaAdvisor %}
                <small class="text-muted">{{ articulo.subcategoriaAdvisor }}</small>
                {% endif %}
            </div>
            <div class="col-auto ms-auto d-flex gap-2 flex-wrap justify-content-end">
                {% if app.user %}
                    <button type="button" class="btn btn-dark btn-sm btn-agregar-proyecto"
                            data-articulo-codigo="{{ articulo.codigoCalipso }}"
                            data-articulo-nombre="{{ articulo.nombreDisplay|e('html_attr') }}">
                        <i class="ri-folder-add-line"></i> Agregar
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" disabled>
                        Pedir cotización
                    </button>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-outline-warning btn-sm">
                        Iniciá sesión para agregar
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{% else %}
{# ---- VISTA GRID (vertical) ---- #}
<div class="card border-0 shadow-sm h-100 catalogo-card-grid">
    <div class="position-relative">
        <div class="bg-light rounded-top d-flex align-items-center justify-content-center"
             style="height:180px;overflow:hidden;">
            {% if articulo.imagen %}
            <img src="{{ articulo.imagen }}" alt="{{ articulo.nombreDisplay }}"
                 class="img-fluid p-3" style="max-height:100%;object-fit:contain;"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div style="display:none" class="w-100 h-100 align-items-center justify-content-center">
                <i class="ri-image-line fs-1 text-muted"></i>
            </div>
            {% else %}
            <i class="ri-image-line fs-1 text-muted"></i>
            {% endif %}
        </div>
        {# Badge de stock #}
        <span class="position-absolute top-0 start-0 m-2 badge rounded-pill"
              style="background:var(--rkl-primary);font-size:.68rem;font-weight:600;letter-spacing:.2px;">En Stock</span>
    </div>
    <div class="card-body p-3 d-flex flex-column">
        <a href="{{ path('app_catalogo_detalle', {codigo: articulo.codigoCalipso}) }}" class="text-decoration-none text-dark"
           onclick="RKL.clarity('event','producto_click');RKL.clarity('set','producto_clickeado','{{ articulo.codigoCalipso|e('html_attr') }}');">
            <h6 class="card-title fw-semibold mb-1 line-clamp-2">{{ articulo.nombreDisplay }}</h6>
        </a>
        {% if articulo.descripcion %}
        <p class="card-text text-muted small mb-2 line-clamp-2">{{ articulo.descripcion }}</p>
        {% endif %}
        {% if articulo.codigoRockwell %}
        <small class="text-muted mb-2 d-block">Cód: {{ articulo.codigoRockwell }}</small>
        {% endif %}
        <div class="mt-auto">
            {% if app.user %}
                <button type="button"
                        class="btn btn-agregar-proyecto w-100"
                        style="border:1.5px solid var(--rkl-primary);color:var(--rkl-primary);background:#fff;border-radius:5px;font-size:.73rem;font-weight:700;letter-spacing:.7px;text-transform:uppercase;padding:.5rem .75rem;transition:background .15s,color .15s;"
                        onmouseover="this.style.background='var(--rkl-primary)';this.style.color='#fff';"
                        onmouseout="this.style.background='#fff';this.style.color='var(--rkl-primary)';"
                        data-articulo-codigo="{{ articulo.codigoCalipso }}"
                        data-articulo-nombre="{{ articulo.nombreDisplay|e('html_attr') }}">
                    Agregar a Proyecto
                </button>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn w-100"
                   style="border:1.5px solid var(--rkl-primary);color:var(--rkl-primary);background:#fff;border-radius:5px;font-size:.73rem;font-weight:700;letter-spacing:.7px;text-transform:uppercase;padding:.5rem .75rem;">
                    Iniciá sesión
                </a>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}
