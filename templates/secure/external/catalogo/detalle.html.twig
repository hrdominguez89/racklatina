{% extends 'base_catalogo.html.twig' %}

{% block title %}{{ articulo.nombreDisplay }}{% endblock %}

{% block breadcrumb %}
<ol class="breadcrumb mb-0">
    <li class="breadcrumb-item">
        <a href="{{ path('app_catalogo_index') }}">Catálogo</a>
    </li>
    {% if articulo.categoriaAdvisor %}
    <li class="breadcrumb-item">
        <a href="{{ path('app_catalogo_lista', {categoria: articulo.categoriaAdvisor}) }}">{{ articulo.categoriaAdvisor }}</a>
    </li>
    {% endif %}
    <li class="breadcrumb-item active">{{ articulo.nombreDisplay|slice(0, 40) }}{% if articulo.nombreDisplay|length > 40 %}…{% endif %}</li>
</ol>
{% endblock %}

{% block body %}
<div class="row g-4">

    {# ── Columna imagen ── #}
    <div class="col-12 col-md-5">
        <div class="card border-0 shadow-sm" style="border-radius:12px;overflow:hidden;">
            <div class="position-relative d-flex align-items-center justify-content-center bg-light"
                 style="min-height:360px;">
                {% if articulo.imagen %}
                <img src="{{ articulo.imagen }}"
                     alt="{{ articulo.nombreDisplay }}"
                     class="img-fluid p-4"
                     style="max-height:340px;object-fit:contain;"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <div style="display:none;min-height:340px;" class="w-100 align-items-center justify-content-center flex-column text-muted">
                    <i class="ri-image-line fs-1 mb-2"></i>
                    <span class="small">Sin imagen</span>
                </div>
                {% else %}
                <div class="d-flex flex-column align-items-center justify-content-center text-muted" style="min-height:340px;">
                    <i class="ri-image-line fs-1 mb-2"></i>
                    <span class="small">Sin imagen</span>
                </div>
                {% endif %}

                <span class="position-absolute top-0 start-0 m-3 badge text-white fw-semibold px-3 py-2"
                      style="background:#111;border-radius:20px;font-size:.75rem;letter-spacing:.3px;">
                    En Stock
                </span>
            </div>
        </div>
    </div>

    {# ── Columna info ── #}
    <div class="col-12 col-md-7">
        <div class="card border-0 shadow-sm h-100 p-4" style="border-radius:12px;">

            {# Categorías #}
            <div class="d-flex gap-2 flex-wrap mb-3">
                {% if articulo.categoriaAdvisor %}
                <a href="{{ path('app_catalogo_lista', {categoria: articulo.categoriaAdvisor}) }}"
                   class="badge bg-light text-dark border text-decoration-none fw-normal">
                    {{ articulo.categoriaAdvisor }}
                </a>
                {% endif %}
                {% if articulo.subcategoriaAdvisor %}
                <span class="badge fw-normal px-2" style="background:#f5f2c0;color:#7a7300;">
                    {{ articulo.subcategoriaAdvisor }}
                </span>
                {% endif %}
            </div>

            {# Nombre #}
            <h4 class="fw-bold mb-1" style="color:#1a1a1a;">{{ articulo.nombreDisplay }}</h4>

            {# Código #}
            {% if articulo.codigoRockwell %}
            <p class="text-muted small mb-1">Ref: <strong>{{ articulo.codigoRockwell }}</strong></p>
            {% endif %}

            {# Descripción corta #}
            {% if articulo.descripcion %}
            <p class="text-muted mb-3" style="font-size:.9rem;line-height:1.6;">{{ articulo.descripcion }}</p>
            {% endif %}

            {# Proveedor / Marca #}
            {% if articulo.proveedor or articulo.marca %}
            <div class="d-flex gap-3 mb-3 small text-muted">
                {% if articulo.proveedor %}
                <span><i class="ri-store-2-line me-1"></i>{{ articulo.proveedor }}</span>
                {% endif %}
                {% if articulo.marca %}
                <span><i class="ri-price-tag-3-line me-1"></i>{{ articulo.marca }}</span>
                {% endif %}
            </div>
            {% endif %}

            <hr class="my-3">

            {# Cantidad #}
            <div class="mb-4">
                <label class="fw-semibold small text-uppercase text-muted d-block mb-2" style="letter-spacing:.5px;">Cantidad</label>
                <div class="d-flex align-items-center gap-0 border rounded-3 d-inline-flex" style="overflow:hidden;width:fit-content;">
                    <button class="btn btn-light border-0 px-3 py-2 fw-bold" type="button" id="btn-menos"
                            style="border-radius:0;background:#f8f9fa;">−</button>
                    <input type="number" id="input-cantidad" value="1" min="1" max="999"
                           class="form-control border-0 text-center fw-semibold"
                           style="width:60px;border-radius:0;box-shadow:none;background:#fff;">
                    <button class="btn btn-light border-0 px-3 py-2 fw-bold" type="button" id="btn-mas"
                            style="border-radius:0;background:#f8f9fa;">+</button>
                </div>
            </div>

            {# Botones #}
            <div class="d-flex gap-2 flex-wrap mb-2">
                {% if app.user %}
                    <button type="button"
                            class="btn fw-semibold px-4 btn-agregar-proyecto"
                            style="background:#1a1a1a;color:#fff;border-radius:8px;"
                            data-articulo-codigo="{{ articulo.codigoCalipso }}"
                            data-articulo-nombre="{{ articulo.nombreDisplay|e('html_attr') }}">
                        <i class="ri-folder-add-line me-1"></i> Agregar a Proyecto
                    </button>
                    <button type="button" class="btn btn-outline-secondary fw-semibold px-4" disabled
                            style="border-radius:8px;">
                        Pedir cotización
                    </button>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-warning fw-semibold px-4"
                       style="border-radius:8px;">
                        Iniciá sesión para agregar
                    </a>
                {% endif %}
            </div>

            {% if app.user and proyectos is empty %}
            <p class="text-muted small mt-1">
                <a href="{{ path('app_proyectos_index') }}" class="text-warning fw-semibold">Creá un proyecto</a>
                para poder agregar productos.
            </p>
            {% endif %}

        </div>
    </div>
</div>

{# ── Acordeones ── #}
<div class="row mt-4">
    <div class="col-12">
        <div class="accordion accordion-flush border rounded-3 overflow-hidden shadow-sm" id="acordeonProducto">

            {% if articulo.descripcionTecnica %}
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button fw-semibold" type="button"
                            data-bs-toggle="collapse" data-bs-target="#acc-caracteristicas"
                            style="font-size:.95rem;">
                        Características técnicas
                    </button>
                </h2>
                <div id="acc-caracteristicas" class="accordion-collapse collapse show">
                    <div class="accordion-body text-muted" style="line-height:1.7;font-size:.9rem;">
                        {{ articulo.descripcionTecnica|nl2br }}
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button"
                            data-bs-toggle="collapse" data-bs-target="#acc-seleccion"
                            style="font-size:.95rem;">
                        Selección de productos
                    </button>
                </h2>
                <div id="acc-seleccion" class="accordion-collapse collapse">
                    <div class="accordion-body text-muted" style="font-size:.9rem;">
                        Agregá este producto a uno de tus proyectos para gestionarlo junto con otros artículos.
                        <a href="{{ path('app_proyectos_index') }}" class="text-warning fw-semibold ms-1">Ver mis proyectos →</a>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button"
                            data-bs-toggle="collapse" data-bs-target="#acc-envios"
                            style="font-size:.95rem;">
                        Envíos
                    </button>
                </h2>
                <div id="acc-envios" class="accordion-collapse collapse">
                    <div class="accordion-body text-muted" style="font-size:.9rem;">
                        Para información sobre envíos y tiempos de entrega, contactate con tu representante comercial.
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

{# ── Relacionados ── #}
{% if relacionados is not empty %}
<div class="row mt-5">
    <div class="col-12 d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0" style="color:#1a1a1a;">Productos más recomendados</h5>
        <a href="{{ path('app_catalogo_lista', {categoria: articulo.categoriaAdvisor}) }}"
           class="fw-semibold text-decoration-none small"
           style="color:var(--rkl-primary);">VER MÁS →</a>
    </div>
    <div class="col-12">
        <div class="row g-3">
            {% for rel in relacionados %}
            <div class="col-6 col-md-3">
                {% include 'secure/external/catalogo/_card_articulo.html.twig' with {articulo: rel, proyectos: proyectos} %}
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

{# Modal: seleccionar proyecto — contenido cargado vía JS #}
<div class="modal fade" id="modalAgregarProyecto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:12px;overflow:hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Agregar a Proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3"><strong>{{ articulo.nombreDisplay }}</strong></p>

                <div id="modal-sin-proyectos" style="display:none;" class="text-center py-3">
                    <i class="ri-folder-line fs-1 text-muted d-block mb-2"></i>
                    <p class="text-muted mb-3">No tenés proyectos para esta empresa.</p>
                    <a href="{{ path('app_proyectos_index') }}" class="btn fw-semibold px-4"
                       style="background:#1a1a1a;color:#fff;border-radius:8px;">Ir a Proyectos</a>
                </div>

                <div id="modal-con-proyectos">
                    <label class="form-label fw-semibold small">Proyecto:</label>
                    <select class="form-select" id="select-proyecto" style="border-radius:8px;">
                        <option>Cargando…</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light fw-semibold px-4" data-bs-dismiss="modal"
                        style="border-radius:8px;">Cancelar</button>
                <button type="button" class="btn fw-semibold px-4" id="btn-confirmar-agregar"
                        style="background:#1a1a1a;color:#fff;border-radius:8px;">Agregar</button>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block extra_js %}
<script>
(function() {
    const articuloCodigo = '{{ articulo.codigoCalipso|e('js') }}';

    async function agregarArticulo(proyectoId, cantidad, btnOrigen) {
        if (btnOrigen) btnOrigen.disabled = true;
        const fd = new FormData();
        fd.append('articulo_codigo', articuloCodigo);
        fd.append('cantidad', cantidad || 1);

        try {
            const res = await fetch(`/secure/proyectos/${proyectoId}/agregar-articulo`, {
                method: 'POST', body: fd,
            });
            const data = await res.json();
            if (data.success) {
                RKL.toast(data.mensaje, 'success');
            } else {
                RKL.toast(data.error || 'Error al agregar', 'danger');
            }
        } catch (e) {
            RKL.toast('Error: ' + e.message, 'danger');
        } finally {
            if (btnOrigen) btnOrigen.disabled = false;
        }
    }

    async function cargarProyectosEnModal() {
        const select              = document.getElementById('select-proyecto');
        const cuerpoSinProyectos  = document.getElementById('modal-sin-proyectos');
        const cuerpoConProyectos  = document.getElementById('modal-con-proyectos');
        const btnConfirmar        = document.getElementById('btn-confirmar-agregar');

        if (select) select.innerHTML = '<option>Cargando…</option>';

        try {
            const res      = await fetch('/secure/proyectos/mis-proyectos-json');
            const proyectos = await res.json();

            if (proyectos.length === 0) {
                if (cuerpoSinProyectos) cuerpoSinProyectos.style.display = '';
                if (cuerpoConProyectos) cuerpoConProyectos.style.display = 'none';
                if (btnConfirmar)       btnConfirmar.style.display       = 'none';
            } else {
                if (cuerpoSinProyectos) cuerpoSinProyectos.style.display = 'none';
                if (cuerpoConProyectos) cuerpoConProyectos.style.display = '';
                if (btnConfirmar)       btnConfirmar.style.display       = '';
                if (select) {
                    select.innerHTML = proyectos.map(p =>
                        `<option value="${p.id}">${p.nombre} (${p.cantidad} items)</option>`
                    ).join('');
                }
            }
        } catch (e) {
            if (select) select.innerHTML = '<option>Error al cargar</option>';
        }
    }

    // Cantidad +/-
    document.getElementById('btn-menos')?.addEventListener('click', () => {
        const inp = document.getElementById('input-cantidad');
        if (parseInt(inp.value) > 1) inp.value = parseInt(inp.value) - 1;
    });
    document.getElementById('btn-mas')?.addEventListener('click', () => {
        const inp = document.getElementById('input-cantidad');
        if (parseInt(inp.value) < 999) inp.value = parseInt(inp.value) + 1;
    });

    // Botón principal
    document.querySelector('.btn-agregar-proyecto')?.addEventListener('click', function () {
        const cantidad = parseInt(document.getElementById('input-cantidad')?.value || 1);

        if (RKL.proyectoActivo) {
            agregarArticulo(RKL.proyectoActivo.id, cantidad, this);
            return;
        }

        cargarProyectosEnModal();
        new bootstrap.Modal(document.getElementById('modalAgregarProyecto')).show();
    });

    // Confirmar desde modal
    document.getElementById('btn-confirmar-agregar')?.addEventListener('click', async function () {
        const proyectoId = document.getElementById('select-proyecto')?.value;
        const cantidad   = parseInt(document.getElementById('input-cantidad')?.value || 1);
        if (!proyectoId) return;

        this.disabled    = true;
        this.textContent = 'Agregando…';
        bootstrap.Modal.getInstance(document.getElementById('modalAgregarProyecto')).hide();
        await agregarArticulo(proyectoId, cantidad);
        this.disabled    = false;
        this.textContent = 'Agregar';
    });
})();
</script>
{% endblock extra_js %}
