{% extends 'base_catalogo.html.twig' %}

{% block title %}Productos{% endblock %}

{% block stylesheets %}
<style>
/* ── Variables ──────────────────────────────────────────── */
:root {
    --rkl-sidebar-w: 260px;
}

/* ── Layout ─────────────────────────────────────────────── */
.rkl-layout {
    display: flex;
    gap: 0;
    min-height: 60vh;
}

/* ── Sidebar Filtros ────────────────────────────────────── */
.rkl-sidebar {
    width: var(--rkl-sidebar-w);
    min-width: var(--rkl-sidebar-w);
    flex-shrink: 0;
    border-right: 1px solid #e8e8e8;
    padding-right: 1.5rem;
}
.rkl-sidebar-title {
    font-size: .7rem;
    font-weight: 800;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 1rem;
}
.rkl-filter-section { margin-bottom: 0; }
.rkl-filter-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .6rem 0;
    border-top: 1px solid #f0f0f0;
    cursor: pointer;
    user-select: none;
}
.rkl-filter-header:first-child { border-top: none; }
.rkl-filter-header-label {
    font-size: .82rem;
    font-weight: 600;
    color: #2c2c2c;
}
.rkl-filter-header i {
    font-size: .9rem;
    color: #aaa;
    transition: transform .2s;
}
.rkl-filter-body { padding-bottom: .5rem; }
.rkl-filter-item {
    display: flex;
    align-items: center;
    gap: .55rem;
    padding: .3rem 0 .3rem .25rem;
    cursor: pointer;
}
.rkl-filter-item label {
    font-size: .8rem;
    color: #444;
    cursor: pointer;
    line-height: 1.3;
}
.rkl-filter-item input[type=radio],
.rkl-filter-item input[type=checkbox] {
    width: 15px; height: 15px;
    flex-shrink: 0;
    accent-color: var(--rkl-primary);
    cursor: pointer;
}
.rkl-filter-item.active label { font-weight: 700; color: #1a1a1a; }

/* ── Content ────────────────────────────────────────────── */
.rkl-content {
    flex: 1;
    min-width: 0;
    padding-left: 2rem;
}

/* ── Page header ────────────────────────────────────────── */
.rkl-page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.2;
}
.rkl-btn-nuevo-proyecto {
    background: var(--rkl-primary) !important;
    color: #1a1a1a !important;
    border: none !important;
    border-radius: 6px !important;
    font-weight: 700 !important;
    font-size: .82rem !important;
    letter-spacing: .5px;
    padding: .6rem 1.4rem !important;
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    white-space: nowrap;
}

/* ── Search bar ─────────────────────────────────────────── */
.rkl-search-wrap {
    position: relative;
}
.rkl-search-icon {
    position: absolute;
    left: 14px; top: 50%; transform: translateY(-50%);
    color: #aaa; font-size: 1rem; pointer-events: none;
}
.rkl-search-input {
    height: 44px;
    padding-left: 2.6rem;
    border: 1px solid #ddd;
    border-radius: 6px !important;
    font-size: .9rem;
    background: #fff;
    color: #333;
    transition: border-color .2s, box-shadow .2s;
}
.rkl-search-input:focus {
    border-color: #bbb;
    box-shadow: 0 0 0 3px rgba(172,163,0,.12);
    outline: none;
}

/* ── Ordenar por ────────────────────────────────────────── */
.rkl-ordenar-btn {
    height: 44px;
    padding: 0 1rem;
    border: 1px solid #ddd !important;
    border-radius: 6px !important;
    background: #fff !important;
    color: #555 !important;
    font-size: .82rem;
    font-weight: 500;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: .3rem;
}
.rkl-ordenar-btn:hover { border-color: #bbb !important; }

/* ── Filter tags ────────────────────────────────────────── */
.rkl-tag {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    background: #f5f3cc;
    color: #6b6200;
    border: 1px solid #d9d472;
    border-radius: 4px;
    padding: .2rem .65rem;
    font-size: .78rem;
    font-weight: 500;
}
.rkl-tag a {
    color: #6b6200;
    text-decoration: none;
    font-size: .9rem;
    line-height: 1;
    opacity: .7;
}
.rkl-tag a:hover { opacity: 1; }

/* ── Section label ──────────────────────────────────────── */
.rkl-section-label {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
}
.rkl-section-link {
    font-size: .78rem;
    font-weight: 600;
    color: var(--rkl-primary);
    text-decoration: none;
    letter-spacing: .3px;
    text-transform: uppercase;
}
.rkl-section-link:hover { color: var(--rkl-primary-dark); }

/* ── Product card ───────────────────────────────────────── */
.rkl-prod-card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: box-shadow .18s, transform .15s;
}
.rkl-prod-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,.1);
    transform: translateY(-2px);
}
.rkl-prod-img-wrap {
    position: relative;
    background: #f8f8f8;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 1px solid #efefef;
}
.rkl-prod-img-wrap img {
    max-height: 170px;
    max-width: 85%;
    object-fit: contain;
}
.rkl-prod-badge {
    position: absolute;
    top: 0; right: 0;
    background: #1a1a1a;
    color: #fff;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .3px;
    padding: .3rem .7rem;
    border-bottom-left-radius: 6px;
}
.rkl-prod-body {
    padding: 1rem 1rem 1.1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
}
.rkl-prod-name {
    font-size: .95rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.3;
    margin-bottom: .3rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.rkl-prod-sub {
    font-size: .78rem;
    color: #888;
    line-height: 1.35;
    margin-bottom: .25rem;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.rkl-prod-meta {
    font-size: .75rem;
    color: #aaa;
    margin-bottom: .9rem;
}
.rkl-btn-agregar {
    display: block;
    width: 100%;
    text-align: center;
    border: 1.5px solid var(--rkl-primary);
    background: #fff;
    color: #6b6200;
    border-radius: 4px;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .9px;
    text-transform: uppercase;
    padding: .6rem .5rem;
    transition: background .15s, color .15s;
    cursor: pointer;
}
.rkl-btn-agregar:hover {
    background: var(--rkl-primary);
    color: #1a1a1a;
}

/* ── Responsive ─────────────────────────────────────────── */
@media (max-width: 767px) {
    .rkl-sidebar {
        display: none;
    }
    .rkl-content {
        padding-left: 0;
    }
}
</style>
{% endblock %}

{% block body %}

{# ── Page header ──────────────────────────────────────── #}
<div class="d-flex justify-content-between align-items-start mb-4">
    <h2 class="rkl-page-title mb-0">Productos</h2>
    {% if app.user %}
    <button type="button"
            class="btn rkl-btn-nuevo-proyecto"
            data-bs-toggle="modal" data-bs-target="#modalCrearProyecto">
        <i class="ri-add-line fs-5"></i> CREAR NUEVO PROYECTO
    </button>
    {% endif %}
</div>

{# ── Layout ───────────────────────────────────────────── #}
<div class="rkl-layout">

    {# ── Sidebar ────────────────────────────────────── #}
    <aside class="rkl-sidebar">
        <p class="rkl-sidebar-title">Filtros</p>

        <form method="GET" action="{{ path('app_catalogo_lista') }}" id="form-filtros">
            <input type="hidden" name="q" value="{{ filtros.q ?? '' }}">
            <input type="hidden" name="ordenar" value="{{ filtros.ordenar ?? 'az' }}">
            <input type="hidden" name="pagina" value="1">

            {# Categorías #}
            {% if opcionesFiltros.categorias is not empty %}
            <div class="rkl-filter-section">
                <div class="rkl-filter-header"
                     data-bs-toggle="collapse" data-bs-target="#fc-categorias">
                    <span class="rkl-filter-header-label">Categoría</span>
                    <i class="ri-arrow-up-s-line"></i>
                </div>
                <div class="collapse show rkl-filter-body" id="fc-categorias">
                    {% for cat in opcionesFiltros.categorias %}
                    <div class="rkl-filter-item {{ filtros.categoria == cat ? 'active' : '' }}">
                        <input type="radio" name="categoria"
                               id="cat-{{ loop.index }}"
                               value="{{ cat }}"
                               class="filtro-check"
                               {{ filtros.categoria == cat ? 'checked' : '' }}>
                        <label for="cat-{{ loop.index }}">{{ cat }}</label>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# Subcategorías #}
            {% if opcionesFiltros.subcategorias is not empty %}
            <div class="rkl-filter-section">
                <div class="rkl-filter-header"
                     data-bs-toggle="collapse" data-bs-target="#fc-subcategorias">
                    <span class="rkl-filter-header-label">Subcategoría</span>
                    <i class="ri-arrow-up-s-line"></i>
                </div>
                <div class="collapse show rkl-filter-body" id="fc-subcategorias">
                    {% for sub in opcionesFiltros.subcategorias %}
                    <div class="rkl-filter-item {{ filtros.subcategoria == sub ? 'active' : '' }}">
                        <input type="radio" name="subcategoria"
                               id="sub-{{ loop.index }}"
                               value="{{ sub }}"
                               class="filtro-check"
                               {{ filtros.subcategoria == sub ? 'checked' : '' }}>
                        <label for="sub-{{ loop.index }}">{{ sub }}</label>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# Marcas #}
            {% if opcionesFiltros.marcas is not empty %}
            <div class="rkl-filter-section">
                <div class="rkl-filter-header"
                     data-bs-toggle="collapse" data-bs-target="#fc-marcas">
                    <span class="rkl-filter-header-label">Marcas</span>
                    <i class="ri-arrow-down-s-line"></i>
                </div>
                <div class="collapse rkl-filter-body" id="fc-marcas">
                    {% for m in opcionesFiltros.marcas %}{% if m %}
                    <div class="rkl-filter-item {{ filtros.marca == m ? 'active' : '' }}">
                        <input type="radio" name="marca"
                               id="marca-{{ loop.index }}"
                               value="{{ m }}"
                               class="filtro-check"
                               {{ filtros.marca == m ? 'checked' : '' }}>
                        <label for="marca-{{ loop.index }}">{{ m }}</label>
                    </div>
                    {% endif %}{% endfor %}
                </div>
            </div>
            {% endif %}

        </form>
    </aside>

    {# ── Content ─────────────────────────────────────── #}
    <div class="rkl-content">

        {# Search + Ordenar #}
        <form method="GET" action="{{ path('app_catalogo_lista') }}" id="form-busqueda">
            {% if filtros.categoria %}<input type="hidden" name="categoria" value="{{ filtros.categoria }}">{% endif %}
            {% if filtros.subcategoria %}<input type="hidden" name="subcategoria" value="{{ filtros.subcategoria }}">{% endif %}
            {% if filtros.marca %}<input type="hidden" name="marca" value="{{ filtros.marca }}">{% endif %}
            <div class="d-flex gap-2 align-items-center mb-3">
                <div class="rkl-search-wrap flex-grow-1">
                    <i class="ri-search-line rkl-search-icon"></i>
                    <input type="text" name="q"
                           class="form-control rkl-search-input"
                           placeholder="Buscá un producto"
                           value="{{ filtros.q ?? '' }}">
                </div>
                <div class="dropdown flex-shrink-0">
                    <button type="button" class="btn rkl-ordenar-btn" data-bs-toggle="dropdown">
                        Ordenar por <i class="ri-arrow-down-s-line"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" style="font-size:.82rem;min-width:130px;">
                        <li>
                            <a class="dropdown-item {{ filtros.ordenar != 'za' ? 'fw-semibold' : '' }}"
                               href="{{ path('app_catalogo_lista', filtros|merge({ordenar: 'az', pagina: 1})) }}">A – Z</a>
                        </li>
                        <li>
                            <a class="dropdown-item {{ filtros.ordenar == 'za' ? 'fw-semibold' : '' }}"
                               href="{{ path('app_catalogo_lista', filtros|merge({ordenar: 'za', pagina: 1})) }}">Z – A</a>
                        </li>
                    </ul>
                </div>
            </div>
        </form>

        {# Filter tags activos #}
        {% if filtros.q or filtros.categoria or filtros.subcategoria or filtros.marca %}
        <div class="d-flex flex-wrap gap-2 mb-3">
            {% if filtros.q %}
            <span class="rkl-tag">
                <a href="{{ path('app_catalogo_lista', filtros|merge({q: null, pagina: 1})) }}">×</a>
                {{ filtros.q }}
            </span>
            {% endif %}
            {% if filtros.categoria %}
            <span class="rkl-tag">
                <a href="{{ path('app_catalogo_lista', filtros|merge({categoria: null, subcategoria: null, pagina: 1})) }}">×</a>
                {{ filtros.categoria }}
            </span>
            {% endif %}
            {% if filtros.subcategoria %}
            <span class="rkl-tag">
                <a href="{{ path('app_catalogo_lista', filtros|merge({subcategoria: null, pagina: 1})) }}">×</a>
                {{ filtros.subcategoria }}
            </span>
            {% endif %}
            {% if filtros.marca %}
            <span class="rkl-tag">
                <a href="{{ path('app_catalogo_lista', filtros|merge({marca: null, pagina: 1})) }}">×</a>
                {{ filtros.marca }}
            </span>
            {% endif %}
        </div>
        {% endif %}

        {# Section label #}
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="rkl-section-label">Productos más recomendados</span>
            {% if total is defined and total > 0 %}
            <span class="text-muted" style="font-size:.78rem;">{{ total }} resultado{{ total != 1 ? 's' : '' }}</span>
            {% endif %}
        </div>

        {# Grid #}
        {% if articulos is empty %}
        <div class="text-center py-5">
            <i class="ri-search-line fs-1 text-muted d-block mb-2"></i>
            <p class="text-muted">No se encontraron productos con los filtros aplicados.</p>
            <a href="{{ path('app_catalogo_lista') }}" class="btn btn-sm mt-1"
               style="border:1.5px solid var(--rkl-primary);color:#6b6200;border-radius:4px;font-size:.82rem;">
                Ver todos los productos
            </a>
        </div>
        {% else %}
        <div class="row g-3">
            {% for articulo in articulos %}
            <div class="col-6 col-xl-4">
                <div class="rkl-prod-card">
                    <div class="rkl-prod-img-wrap">
                        {% if articulo.imagen %}
                        <img src="{{ articulo.imagen }}" alt="{{ articulo.nombreDisplay }}"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <div style="display:none;width:100%;height:100%;align-items:center;justify-content:center;">
                            <i class="ri-image-line fs-1 text-muted"></i>
                        </div>
                        {% else %}
                        <i class="ri-image-line fs-1 text-muted"></i>
                        {% endif %}
                        <span class="rkl-prod-badge">En Stock</span>
                    </div>
                    <div class="rkl-prod-body">
                        <a href="{{ path('app_catalogo_detalle', {codigo: articulo.codigoCalipso}) }}"
                           class="text-decoration-none"
                           onclick="RKL.clarity('event','producto_click');RKL.clarity('set','producto_clickeado','{{ articulo.codigoCalipso|e('html_attr') }}');">
                            <p class="rkl-prod-name">{{ articulo.nombreDisplay }}</p>
                        </a>
                        {% if articulo.subcategoriaAdvisor %}
                        <p class="rkl-prod-sub">{{ articulo.subcategoriaAdvisor }}</p>
                        {% elseif articulo.descripcion %}
                        <p class="rkl-prod-sub">{{ articulo.descripcion }}</p>
                        {% endif %}
                        {% if articulo.marca %}
                        <p class="rkl-prod-meta">{{ articulo.marca }}</p>
                        {% endif %}
                        <div class="mt-auto">
                            {% if app.user %}
                            <button type="button"
                                    class="rkl-btn-agregar btn-agregar-proyecto"
                                    data-articulo-codigo="{{ articulo.codigoCalipso }}"
                                    data-articulo-nombre="{{ articulo.nombreDisplay|e('html_attr') }}">
                                Agregar a Proyecto
                            </button>
                            {% else %}
                            <a href="{{ path('app_login') }}" class="rkl-btn-agregar" style="display:block;text-align:center;">
                                Iniciá sesión
                            </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# Paginación #}
        {% if totalPaginas > 1 %}
        <nav class="mt-4 d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="d-flex align-items-center gap-2">
                <span class="small text-muted">Mostrar:</span>
                {% for n in [24, 48, 72] %}
                <a href="{{ path('app_catalogo_lista', filtros|merge({por_pagina: n, pagina: 1})) }}"
                   class="btn btn-sm {{ porPagina == n ? 'btn-warning' : 'btn-outline-secondary' }}"
                   style="border-radius:4px;font-size:.78rem;">{{ n }}</a>
                {% endfor %}
            </div>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item {{ pagina == 1 ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_catalogo_lista', filtros|merge({pagina: pagina - 1, por_pagina: porPagina})) }}">
                        <i class="ri-arrow-left-s-line"></i>
                    </a>
                </li>
                {% for p in 1..totalPaginas %}
                {% if p == 1 or p == totalPaginas or (p >= pagina - 2 and p <= pagina + 2) %}
                <li class="page-item {{ pagina == p ? 'active' : '' }}">
                    <a class="page-link" href="{{ path('app_catalogo_lista', filtros|merge({pagina: p, por_pagina: porPagina})) }}">{{ p }}</a>
                </li>
                {% elseif p == pagina - 3 or p == pagina + 3 %}
                <li class="page-item disabled"><span class="page-link">…</span></li>
                {% endif %}
                {% endfor %}
                <li class="page-item {{ pagina == totalPaginas ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_catalogo_lista', filtros|merge({pagina: pagina + 1, por_pagina: porPagina})) }}">
                        <i class="ri-arrow-right-s-line"></i>
                    </a>
                </li>
            </ul>
        </nav>
        {% endif %}

    </div>{# /content #}
</div>{# /layout #}

{% endblock %}

{% block extra_js %}
<script>
(function() {
    let articuloCodigoActual = null;
    let articuloNombreActual = null;

    async function agregarArticulo(proyectoId, articuloCodigo, cantidad, btnOrigen) {
        if (btnOrigen) btnOrigen.disabled = true;
        const fd = new FormData();
        fd.append('articulo_codigo', articuloCodigo);
        fd.append('cantidad', cantidad || 1);
        try {
            const res  = await fetch(`/secure/proyectos/${proyectoId}/agregar-articulo`, { method: 'POST', body: fd });
            const data = await res.json();
            if (data.success) {
                RKL.clarity('event', 'producto_agregado');
                RKL.clarity('set', 'producto_agregado', articuloCodigo);
                RKL.toast(data.mensaje, 'success');
            } else {
                RKL.toast(data.error || 'Error al agregar', 'danger');
            }
        } catch (e) {
            RKL.toast('Error de red: ' + e.message, 'danger');
        } finally {
            if (btnOrigen) btnOrigen.disabled = false;
        }
    }

    async function cargarProyectosEnModal() {
        const select             = document.getElementById('select-proyecto');
        const cuerpoSinProyectos = document.getElementById('modal-sin-proyectos');
        const cuerpoConProyectos = document.getElementById('modal-con-proyectos');
        const btnConfirmar       = document.getElementById('btn-confirmar-agregar');
        if (select) select.innerHTML = '<option>Cargando…</option>';
        try {
            const proyectos = await fetch('/secure/proyectos/mis-proyectos-json').then(r => r.json());
            if (proyectos.length === 0) {
                if (cuerpoSinProyectos) cuerpoSinProyectos.style.display = '';
                if (cuerpoConProyectos) cuerpoConProyectos.style.display = 'none';
                if (btnConfirmar)       btnConfirmar.style.display       = 'none';
            } else {
                if (cuerpoSinProyectos) cuerpoSinProyectos.style.display = 'none';
                if (cuerpoConProyectos) cuerpoConProyectos.style.display = '';
                if (btnConfirmar)       btnConfirmar.style.display       = '';
                if (select) select.innerHTML = proyectos.map(p =>
                    `<option value="${p.id}">${p.nombre} (${p.cantidad} items)</option>`
                ).join('');
            }
        } catch (e) {
            if (select) select.innerHTML = '<option>Error al cargar</option>';
        }
    }

    document.querySelectorAll('.btn-agregar-proyecto').forEach(btn => {
        btn.addEventListener('click', function () {
            articuloCodigoActual = this.dataset.articuloCodigo;
            articuloNombreActual = this.dataset.articuloNombre;
            if (RKL.proyectoActivo) {
                agregarArticulo(RKL.proyectoActivo.id, articuloCodigoActual, 1, this);
                return;
            }
            const el = document.getElementById('modal-articulo-nombre');
            if (el) el.textContent = articuloNombreActual;
            cargarProyectosEnModal();
            new bootstrap.Modal(document.getElementById('modalAgregarProyecto')).show();
        });
    });

    document.getElementById('btn-confirmar-agregar')?.addEventListener('click', async function () {
        const proyectoId = document.getElementById('select-proyecto')?.value;
        const cantidad   = document.getElementById('input-cantidad')?.value || 1;
        if (!proyectoId || !articuloCodigoActual) return;
        this.disabled    = true;
        this.textContent = 'Agregando…';
        bootstrap.Modal.getInstance(document.getElementById('modalAgregarProyecto')).hide();
        await agregarArticulo(proyectoId, articuloCodigoActual, cantidad);
        this.disabled    = false;
        this.textContent = 'Agregar';
    });

    document.getElementById('btn-menos')?.addEventListener('click', () => {
        const inp = document.getElementById('input-cantidad');
        if (inp && parseInt(inp.value) > 1) inp.value = parseInt(inp.value) - 1;
    });
    document.getElementById('btn-mas')?.addEventListener('click', () => {
        const inp = document.getElementById('input-cantidad');
        if (inp && parseInt(inp.value) < 999) inp.value = parseInt(inp.value) + 1;
    });

    // Auto-submit filtros
    document.querySelectorAll('.filtro-check').forEach(el => {
        el.addEventListener('change', () => document.getElementById('form-filtros').submit());
    });

    // Auto-submit búsqueda con debounce
    let searchTimer;
    document.querySelector('#form-busqueda input[name=q]')?.addEventListener('input', function () {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(() => document.getElementById('form-busqueda').submit(), 500);
    });

    // Rotar flecha de collapse
    document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(trigger => {
        const icon = trigger.querySelector('i');
        if (!icon) return;
        const target = document.querySelector(trigger.dataset.bsTarget);
        if (!target) return;
        target.addEventListener('hide.bs.collapse', () => {
            icon.classList.replace('ri-arrow-up-s-line', 'ri-arrow-down-s-line');
        });
        target.addEventListener('show.bs.collapse', () => {
            icon.classList.replace('ri-arrow-down-s-line', 'ri-arrow-up-s-line');
        });
    });
})();
</script>

{# ── Modal Agregar a Proyecto ──────────────────────────── #}
<div class="modal fade" id="modalAgregarProyecto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:12px;overflow:hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Agregar a Proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3" id="modal-articulo-nombre"></p>
                <div id="modal-sin-proyectos" style="display:none;" class="text-center py-3">
                    <i class="ri-folder-line fs-1 text-muted d-block mb-2"></i>
                    <p class="text-muted mb-3">No tenés proyectos para esta empresa.</p>
                    <a href="{{ path('app_proyectos_index') }}" class="btn fw-semibold px-4"
                       style="background-color:var(--rkl-primary);color:#1a1a1a;border:none;">
                        Ir a Proyectos
                    </a>
                </div>
                <div id="modal-con-proyectos">
                    <label class="form-label fw-semibold">Proyecto:</label>
                    <select class="form-select mb-3" id="select-proyecto"><option>Cargando…</option></select>
                    <label class="form-label fw-semibold">Cantidad:</label>
                    <div class="input-group" style="max-width:140px;">
                        <button class="btn btn-outline-secondary" type="button" id="btn-menos">−</button>
                        <input type="number" class="form-control text-center" id="input-cantidad" value="1" min="1" max="999">
                        <button class="btn btn-outline-secondary" type="button" id="btn-mas">+</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light fw-semibold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn fw-semibold px-4" id="btn-confirmar-agregar"
                        style="background-color:var(--rkl-primary);color:#1a1a1a;border:none;">
                    Agregar
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock extra_js %}
