{% extends 'base_catalogo.html.twig' %}

{% set isFinished = proyecto.status.value == 'finished' %}

{% block title %}{{ proyecto.nombre }}{% endblock %}

{% block breadcrumb %}
<ol class="breadcrumb mb-0">
    <li class="breadcrumb-item">
        <a href="{{ path('app_proyectos_index') }}">Proyectos</a>
    </li>
    <li class="breadcrumb-item active">{{ proyecto.nombre|slice(0,40) }}{% if proyecto.nombre|length > 40 %}…{% endif %}</li>
</ol>
{% endblock %}

{% block stylesheets %}
<style>
/* ── Layout principal ── */
.proyecto-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 1.5rem;
    align-items: start;
}
@media (max-width: 991px) {
    .proyecto-layout { grid-template-columns: 1fr; }
    .proyecto-sidebar { order: -1; }
}

/* ── Tabla de productos ── */
.tabla-productos {
    width: 100%;
    border-collapse: collapse;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    overflow: hidden;
}
.tabla-productos thead tr {
    background: #f0f0f0;
}
.tabla-productos thead th {
    padding: .75rem 1rem;
    font-size: .82rem;
    font-weight: 600;
    color: #555;
    text-align: center;
    border-bottom: 1px solid #e0e0e0;
    white-space: nowrap;
}
.tabla-productos thead th.col-producto {
    text-align: left;
    padding-left: 1.25rem;
}

/* ── Filas de producto ── */
.tr-producto {
    border-bottom: 1px solid #efefef;
}
.tr-producto:last-of-type {
    border-bottom: none;
}
.tr-producto td {
    padding: .9rem 1rem;
    vertical-align: middle;
    text-align: center;
}
.tr-producto td.td-producto {
    text-align: left;
    padding-left: 1.25rem;
}

/* ── Celda producto ── */
.td-producto-inner {
    display: flex;
    align-items: center;
    gap: .85rem;
}
.td-producto-img {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    background: #f5f5f5;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}
.td-producto-img img {
    max-width: 100%;
    max-height: 60px;
    object-fit: contain;
    padding: .3rem;
    mix-blend-mode: multiply;
}
.td-producto-info { min-width: 0; }
.td-producto-nombre {
    font-size: .9rem;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
    display: block;
    line-height: 1.35;
}
.td-producto-nombre:hover { color: #1a1a1a; text-decoration: underline; }
.td-ver-producto,
.btn-ver-similares {
    font-size: .78rem;
    color: var(--rkl-primary);
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-weight: 400;
    transition: color .12s;
    display: inline;
}
.td-ver-producto:hover,
.btn-ver-similares:hover { color: var(--rkl-primary-dark); }

/* ── Qty stepper ── */
.qty-ctrl {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    overflow: hidden;
    height: 34px;
}
.qty-ctrl button {
    background: #f5f5f5;
    border: none;
    width: 30px;
    font-size: 1rem;
    font-weight: 600;
    color: #555;
    cursor: pointer;
    line-height: 1;
    transition: background .12s;
    display: flex;
    align-items: center;
    justify-content: center;
}
.qty-ctrl button:hover { background: #e8e8e8; }
.qty-ctrl input {
    border: none;
    border-left: 1px solid #d0d0d0;
    border-right: 1px solid #d0d0d0;
    width: 44px;
    text-align: center;
    font-weight: 600;
    font-size: .88rem;
    background: #fff;
    outline: none;
    box-shadow: none;
    -moz-appearance: textfield;
}
.qty-ctrl input::-webkit-outer-spin-button,
.qty-ctrl input::-webkit-inner-spin-button { -webkit-appearance: none; }

/* ── Checkbox reemplazo ── */
.check-reemplazo {
    width: 16px;
    height: 16px;
    accent-color: var(--rkl-primary);
    cursor: pointer;
    margin: 0 auto;
    display: block;
    border: 1px solid #ccc;
}

/* ── Textarea comentario ── */
.textarea-comentario {
    width: 100%;
    min-width: 160px;
    font-size: .8rem;
    color: #444;
    border: 1px solid #e0e0e0;
    border-radius: 5px;
    padding: .45rem .6rem;
    resize: none;
    outline: none;
    line-height: 1.5;
    background: #fff;
    transition: border-color .15s;
}
.textarea-comentario:focus { border-color: #bbb; }
.textarea-comentario::placeholder { color: #bbb; }
.comment-status {
    font-size: .7rem;
    color: #aaa;
    text-align: right;
    min-height: 1em;
    margin-top: .1rem;
}

/* ── Btn quitar ── */
.btn-quitar-item {
    background: none;
    border: none;
    padding: .3rem .4rem;
    color: #ACA300;
    cursor: pointer;
    border-radius: 4px;
    font-size: 1.15rem;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color .15s, background .15s;
}
.btn-quitar-item:hover { color: #dc3545; background: #fde8e8; }

/* ── Fila "Ver items similares" ── */
.tr-similares-toggle {
    background: #fafafa;
    border-bottom: 1px solid #efefef;
}
.tr-similares-toggle td {
    padding: .45rem 1.25rem;
    text-align: center;
}

/* ── Panel similares (expandible) ── */
.tr-similares-panel { display: none; }
.tr-similares-panel.open { display: table-row; }
.similares-panel-inner {
    padding: 1rem 1.25rem 1.25rem;
    background: #f8f9fa;
    border-top: 1px solid #e9ecef;
}
.similares-panel-title {
    font-size: .78rem;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    letter-spacing: .5px;
    margin-bottom: .75rem;
}
.sim-card {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 6px;
    padding: .75rem;
    display: flex;
    gap: .75rem;
    align-items: center;
    height: 100%;
}
.sim-card-img {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    background: #f0f0f0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}
.sim-card-img img { max-width: 100%; max-height: 100%; object-fit: contain; padding: .25rem; }
.sim-card-body { flex: 1; min-width: 0; }
.sim-card-name {
    font-size: .8rem;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.35;
    margin-bottom: .3rem;
}
.sim-card-name:hover { text-decoration: underline; color: #1a1a1a; }
.sim-card-desc {
    font-size: .73rem;
    color: #888;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: .4rem;
}
.btn-sim-agregar {
    font-size: .73rem;
    font-weight: 600;
    padding: .2rem .55rem;
    background: #2C3E50;
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    white-space: nowrap;
    transition: background .12s;
}
.btn-sim-agregar:hover { background: #3d5166; }

/* ── Sidebar Solicitud ── */
.proyecto-sidebar .sidebar-card {
    background: #FAFAE8;
    border: 1px solid #E8E6C0;
    border-radius: 8px;
    padding: 1.25rem;
    position: sticky;
    top: 80px;
}
.sidebar-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 1rem;
}
.sidebar-items-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}
.sidebar-items-label {
    font-size: .85rem;
    font-weight: 600;
    color: #1a1a1a;
}
.sidebar-items-count {
    font-size: .95rem;
    font-weight: 700;
    color: #1a1a1a;
}
.btn-solicitar-sidebar {
    background: var(--rkl-primary);
    color: #fff;
    border: none;
    border-radius: 5px;
    padding: .7rem 1rem;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    width: 100%;
    text-align: center;
    transition: background .15s;
    display: block;
    margin-bottom: .75rem;
}
.btn-solicitar-sidebar:not(:disabled):hover { background: var(--rkl-primary-dark); }
.btn-solicitar-sidebar:disabled { opacity: .65; cursor: default; }
.sidebar-link {
    font-size: .85rem;
    color: #333;
    text-decoration: underline;
    text-align: center;
    display: block;
}
.sidebar-link:hover { color: #000; }

/* ── Filas pares (al final para ganar en cascada) ── */
.tr-producto.fila-par td { background: #e8e8e8 !important; }
.tr-similares-toggle.fila-par td { background: #e2e2e2 !important; }
</style>
{% endblock %}

{% block body %}

{# Cabecera #}
<h4 class="fw-bold mb-4" style="color:#1a1a1a;">{{ proyecto.nombre }}</h4>

{% if isFinished %}
<div class="alert d-flex align-items-center gap-2 mb-4"
     style="background:#f0f0f0;border:1px solid #ddd;border-radius:8px;font-size:.88rem;color:#555;padding:.75rem 1rem;">
    <i class="ri-lock-line" style="font-size:1.1rem;flex-shrink:0;"></i>
    <span>Este proyecto está <strong>finalizado</strong>. Solo podés consultar su contenido.</span>
</div>
{% endif %}

{% if proyecto.items is empty %}

<div class="text-center py-5">
    <i class="ri-shopping-bag-line" style="font-size:3rem;color:#ccc;"></i>
    <h5 class="text-muted mt-3">El proyecto está vacío</h5>
    <p class="text-muted small mb-4">Agregá productos desde el catálogo para armar tu pedido.</p>
    <a href="{{ path('app_catalogo_lista') }}" class="btn btn-warning fw-semibold px-4">
        <i class="ri-store-2-line me-1"></i> Ir al catálogo
    </a>
</div>

{% else %}

<div class="proyecto-layout">

    {# ── Tabla de productos ── #}
    <div class="proyecto-items">
        <p class="mb-2" style="font-size:.95rem;font-weight:600;color:#333;">Listado de productos</p>

        <table class="tabla-productos">
            <thead>
                <tr>
                    <th class="col-producto">Producto</th>
                    <th>Cantidad</th>
                    <th>Sugerir remplazo<br>por precio</th>
                    <th>Sugerir remplazo<br>por plazo</th>
                    {# <th>Dejá un<br>comentario</th> #}
                    <th></th>
                </tr>
            </thead>
            <tbody id="lista-items">
            {% for item in proyecto.items %}

                {# Fila principal del producto #}
                <tr class="tr-producto{% if loop.index is even %} fila-par{% endif %}" data-item-id="{{ item.id }}">

                    {# Producto #}
                    <td class="td-producto">
                        <div class="td-producto-inner">
                            <div class="td-producto-img">
                                {% if item.articulo.imagen %}
                                <img src="{{ item.articulo.imagen }}" alt="{{ item.articulo.nombreDisplay }}"
                                     onerror="this.style.display='none';this.closest('.td-producto-img').innerHTML='<i class=\'ri-image-line\' style=\'color:#ccc;font-size:1.4rem;\'></i>'">
                                {% else %}
                                <i class="ri-image-line" style="color:#ccc;font-size:1.4rem;"></i>
                                {% endif %}
                            </div>
                            <div class="td-producto-info">
                                <span class="td-producto-nombre">{{ item.articulo.nombreDisplay }}</span>
                                <a href="{{ path('app_catalogo_detalle', {codigo: item.articulo.codigoCalipso}) }}"
                                   class="td-ver-producto">Ver producto</a>
                                <div>
                                    <button type="button"
                                            class="btn-ver-similares"
                                            data-codigo="{{ item.articulo.codigoCalipso }}"
                                            data-panel="similares-{{ item.id }}">
                                        Ver items similares
                                    </button>
                                </div>
                            </div>
                        </div>
                    </td>

                    {# Cantidad #}
                    <td>
                        <div class="qty-ctrl">
                            <button type="button" class="btn-item-menos" data-item="{{ item.id }}"
                                    {% if isFinished %}disabled{% endif %}>−</button>
                            <input type="number" class="input-item-cantidad"
                                   value="{{ item.cantidad }}" min="1" max="999"
                                   data-item="{{ item.id }}"
                                   {% if isFinished %}disabled{% endif %}>
                            <button type="button" class="btn-item-mas" data-item="{{ item.id }}"
                                    {% if isFinished %}disabled{% endif %}>+</button>
                        </div>
                    </td>

                    {# Sugerir remplazo por precio #}
                    <td>
                        <input type="checkbox" class="check-reemplazo input-item-auth" data-item="{{ item.id }}" data-type="precio"
                               {% if isFinished %}disabled{% endif %}>
                    </td>

                    {# Sugerir remplazo por plazo #}
                    <td>
                        <input type="checkbox" class="check-reemplazo input-item-auth-plazo" data-item="{{ item.id }}" data-type="plazo"
                               {% if isFinished %}disabled{% endif %}>
                    </td>

                    {# Comentario #}
                    {# <td>
                        <textarea rows="2"
                                  class="textarea-comentario input-item-comment"
                                  placeholder="Escribí tu comentario..."
                                  data-item="{{ item.id }}"
                                  {% if isFinished %}disabled{% endif %}>{{ item.comment }}</textarea>
                        <div class="comment-status" data-item="{{ item.id }}"></div>
                    </td> #}

                    {# Quitar #}
                    <td>
                        {% if not isFinished %}
                        <button class="btn-quitar-item" data-item="{{ item.id }}"
                                data-nombre="{{ item.articulo.nombreDisplay|e('html_attr') }}"
                                title="Quitar del proyecto">
                            <i class="ri-delete-bin-line"></i>
                        </button>
                        {% endif %}
                    </td>

                </tr>

                {# Fila panel similares (oculta por defecto) #}
                <tr class="tr-similares-panel" id="similares-{{ item.id }}" data-loaded="false">
                    <td colspan="5">
                        <div class="similares-panel-inner">
                            <div class="similares-panel-title">Productos similares</div>
                            <div class="similares-grid row g-2"></div>
                        </div>
                    </td>
                </tr>

            {% endfor %}
            </tbody>
        </table>
    </div>

    {# ── Sidebar Solicitud ── #}
    <div class="proyecto-sidebar">
        <div class="sidebar-card">
            <div class="sidebar-title">Solicitud</div>

            <div class="sidebar-items-row">
                <span class="sidebar-items-label">Cantidad de items a cotizar</span>
                <span class="sidebar-items-count" id="sidebar-items-count">{{ proyecto.cantidadProductos }}</span>
            </div>

            {% if isFinished %}
            <div class="text-center py-2" style="font-size:.82rem;color:#888;">
                <i class="ri-lock-line me-1"></i> Proyecto finalizado
            </div>
            {% else %}
            <button type="button" class="btn-solicitar-sidebar"
                    id="btn-solicitar-pedido"
                    onclick="RKL.clarity('event','solicitar_pedido');RKL.clarity('set','proyecto_cotizado','{{ proyecto.id }}');"
                    {% if proyecto.cantidadProductos == 0 %}disabled{% endif %}>
                Solicitar Cotización
            </button>

            <a href="{{ path('app_catalogo_lista') }}" class="sidebar-link">
                Seguir sumando productos
            </a>
            {% endif %}
        </div>
    </div>

</div>

{% endif %}

{# ── Modal: confirmar eliminación de item ── #}
<div class="modal fade" id="modalEliminarItem" tabindex="-1" aria-labelledby="modalEliminarItemLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content" style="border-radius:12px;border:none;box-shadow:0 8px 32px rgba(0,0,0,.15);">
            <div class="modal-body p-4 text-center">
                <div style="width:60px;height:60px;background:#fde8e8;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem;">
                    <i class="ri-delete-bin-line" style="font-size:1.6rem;color:#e05252;"></i>
                </div>
                <h5 class="fw-bold mb-2" style="font-size:1.05rem;">¿Quitar producto?</h5>
                <p class="mb-1" style="font-size:.9rem;color:#444;">
                    <span id="modal-item-nombre" class="fw-semibold"></span>
                    <span class="text-muted"> será eliminado del proyecto.</span>
                </p>
                <p class="text-muted mb-0" style="font-size:.8rem;">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4 px-4 gap-2 justify-content-center">
                <button type="button" class="btn btn-outline-secondary px-4 fw-semibold" data-bs-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn px-4 fw-semibold" id="btn-confirmar-eliminar-item"
                        style="background:#dc3545;color:#fff;">
                    <i class="ri-delete-bin-line me-1"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block extra_js %}
<script>
(function () {

    const isFinished = {{ isFinished ? 'true' : 'false' }};

    // ── Actualizar cantidad vía AJAX ──
    async function actualizarCantidad(itemId, cantidad) {
        const fd = new FormData();
        fd.append('cantidad', cantidad);
        await fetch(`/secure/proyectos/item/${itemId}/cantidad`, { method: 'POST', body: fd });
    }

    if (isFinished) return;

    // ── Modal eliminar item ──
    let pendingDeleteId = null;
    const _modalEl = document.getElementById('modalEliminarItem');
    const _bsModal = bootstrap.Modal.getOrCreateInstance(_modalEl);

    function abrirModalEliminar(id) {
        const row    = document.querySelector(`.tr-producto[data-item-id="${id}"]`);
        const btn    = row ? row.querySelector('.btn-quitar-item') : null;
        const nombre = btn ? btn.dataset.nombre : 'Este producto';
        pendingDeleteId = id;
        document.getElementById('modal-item-nombre').textContent = nombre;
        _bsModal.show();
    }

    document.getElementById('btn-confirmar-eliminar-item').addEventListener('click', async function () {
        if (!pendingDeleteId) return;
        const id = pendingDeleteId;
        pendingDeleteId = null;
        _bsModal.hide();
        const fd  = new FormData();
        const res = await fetch(`/secure/proyectos/item/${id}/quitar`, { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) {
            // Eliminar las 3 filas del item (producto + toggle similares + panel similares)
            const rowProducto  = document.querySelector(`.tr-producto[data-item-id="${id}"]`);
            const rowToggle    = rowProducto ? rowProducto.nextElementSibling : null;
            const rowPanel     = rowToggle   ? rowToggle.nextElementSibling   : null;
            if (rowPanel)   rowPanel.remove();
            if (rowToggle)  rowToggle.remove();
            if (rowProducto) rowProducto.remove();
            actualizarSidebar();
            if (!document.querySelector('.tr-producto')) location.reload();
        }
    });

    // ── Botón − (decrementar) ──
    document.querySelectorAll('.btn-item-menos').forEach(btn => {
        btn.addEventListener('click', function () {
            const id    = this.dataset.item;
            const input = document.querySelector(`.input-item-cantidad[data-item="${id}"]`);
            const val   = parseInt(input.value);
            if (val > 1) {
                input.value = val - 1;
                actualizarCantidad(id, input.value);
            } else {
                abrirModalEliminar(id);
            }
        });
    });

    // ── Botón + (incrementar) ──
    document.querySelectorAll('.btn-item-mas').forEach(btn => {
        btn.addEventListener('click', function () {
            const id    = this.dataset.item;
            const input = document.querySelector(`.input-item-cantidad[data-item="${id}"]`);
            const val   = parseInt(input.value);
            if (val < 999) {
                input.value = val + 1;
                actualizarCantidad(id, input.value);
            }
        });
    });

    // ── Cambio manual de input ──
    document.querySelectorAll('.input-item-cantidad').forEach(input => {
        input.addEventListener('change', function () {
            const v = Math.max(1, Math.min(999, parseInt(this.value) || 1));
            this.value = v;
            actualizarCantidad(this.dataset.item, v);
        });
    });

    // ── Quitar item ──
    document.querySelectorAll('.btn-quitar-item').forEach(btn => {
        btn.addEventListener('click', function () {
            abrirModalEliminar(this.dataset.item);
        });
    });

    // ── Actualizar sidebar (contador) ──
    function actualizarSidebar() {
        const n = document.querySelectorAll('.tr-producto').length;
        const countEl = document.getElementById('sidebar-items-count');
        if (countEl) countEl.textContent = n;
        const btnPedido = document.getElementById('btn-solicitar-pedido');
        if (btnPedido) btnPedido.disabled = n === 0;
    }

    // ── Productos similares ──
    function renderSimilares(grid, items) {
        if (!items.length) {
            grid.innerHTML = '<p class="text-muted small mb-0">No se encontraron productos similares.</p>';
            return;
        }
        grid.innerHTML = items.map(a => `
            <div class="col-6 col-lg-3">
                <div class="sim-card">
                    <div class="sim-card-img">
                        ${a.imagen
                            ? `<img src="${a.imagen}" alt="" onerror="this.style.display='none'">`
                            : `<i class="ri-image-line" style="color:#ccc;font-size:1.2rem;"></i>`}
                    </div>
                    <div class="sim-card-body">
                        <a href="/catalogo/productos/${encodeURIComponent(a.codigo)}" class="sim-card-name"
                           onclick="RKL.clarity('event','similar_click');RKL.clarity('set','similar_clickeado',${JSON.stringify(a.codigo)});">${a.nombre}</a>
                        ${a.descripcion ? `<div class="sim-card-desc">${a.descripcion}</div>` : ''}
                        <button type="button" class="btn-sim-agregar"
                                data-articulo-codigo="${a.codigo}"
                                data-articulo-nombre="${a.nombre.replace(/"/g, '&quot;')}">
                            + Agregar
                        </button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    document.querySelectorAll('.btn-ver-similares').forEach(btn => {
        btn.addEventListener('click', async function () {
            const panelId = this.dataset.panel;
            const codigo  = this.dataset.codigo;
            const panelRow = document.getElementById(panelId);
            const grid    = panelRow.querySelector('.similares-grid');
            const isOpen  = panelRow.classList.contains('open');

            if (isOpen) {
                panelRow.classList.remove('open');
                this.textContent = 'Ver items similares';
                return;
            }

            panelRow.classList.add('open');
            this.textContent = 'Ocultar similares';
            RKL.clarity('event', 'similares_abierto');
            RKL.clarity('set', 'similares_de', codigo);

            if (panelRow.dataset.loaded === 'true') return;

            grid.innerHTML = '<div class="text-muted small py-2"><i class="ri-loader-4-line me-1"></i> Cargando…</div>';

            try {
                const res  = await fetch(`/catalogo/productos/${encodeURIComponent(codigo)}/similares`);
                const data = await res.json();
                panelRow.dataset.loaded = 'true';
                renderSimilares(grid, data);
            } catch {
                grid.innerHTML = '<p class="text-muted small mb-0">Error al cargar productos similares.</p>';
            }
        });
    });

    // ── Guardar comentario vía AJAX ──
    let commentTimers = {};
    document.querySelectorAll('.input-item-comment').forEach(ta => {
        ta.addEventListener('input', function () {
            const id     = this.dataset.item;
            const status = document.querySelector(`.comment-status[data-item="${id}"]`);
            clearTimeout(commentTimers[id]);
            if (status) status.textContent = 'Escribiendo…';
            commentTimers[id] = setTimeout(async () => {
                const fd = new FormData();
                fd.append('comment', this.value);
                try {
                    const res  = await fetch(`/secure/proyectos/item/${id}/comment`, { method: 'POST', body: fd });
                    const data = await res.json();
                    if (status) status.textContent = data.success ? 'Guardado ✓' : 'Error al guardar';
                    if (data.success) setTimeout(() => { if (status) status.textContent = ''; }, 2000);
                } catch {
                    if (status) status.textContent = 'Error al guardar';
                }
            }, 700);
        });
    });

    // ── Agregar similar al proyecto actual ──
    const PROYECTO_ID = {{ proyecto.id }};
    document.addEventListener('click', async function (e) {
        const btn = e.target.closest('.btn-sim-agregar');
        if (!btn) return;
        const codigo = btn.dataset.articuloCodigo;
        if (!codigo) return;
        btn.disabled = true;
        btn.textContent = 'Agregando…';
        try {
            const fd = new FormData();
            fd.append('articulo_codigo', codigo);
            fd.append('cantidad', 1);
            const res  = await fetch(`/secure/proyectos/${PROYECTO_ID}/agregar-articulo`, { method: 'POST', body: fd });
            const data = await res.json();
            if (data.success) {
                RKL.toast(data.mensaje, 'success');
                setTimeout(() => location.reload(), 800);
            } else {
                RKL.toast(data.error || 'Error al agregar', 'danger');
                btn.disabled = false;
                btn.textContent = '+ Agregar';
            }
        } catch {
            RKL.toast('Error de red', 'danger');
            btn.disabled = false;
            btn.textContent = '+ Agregar';
        }
    });

})();
</script>
{% endblock %}
