{% extends 'base_catalogo.html.twig' %}

{% block title %}{{ proyecto.nombre }}{% endblock %}

{% block breadcrumb %}
<ol class="breadcrumb mb-0">
    <li class="breadcrumb-item">
        <a href="{{ path('app_proyectos_index') }}">Proyectos</a>
    </li>
    <li class="breadcrumb-item active">{{ proyecto.nombre|slice(0,40) }}{% if proyecto.nombre|length > 40 %}…{% endif %}</li>
</ol>
{% endblock %}

{% block stylesheets %}
<style>
/* ── Layout ── */
.proyecto-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 1.5rem;
    align-items: start;
}
@media (max-width: 991px) {
    .proyecto-layout { grid-template-columns: 1fr; }
    .proyecto-sidebar { order: -1; }
}

/* ── Item card ── */
.proy-item-card {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    padding: 1rem 1.25rem 0;
    display: flex;
    flex-direction: column;
    margin-bottom: .85rem;
}
.proy-item-main {
    display: flex;
    gap: 1.1rem;
    align-items: stretch;
    padding-bottom: .85rem;
}

.proy-item-img {
    width: 110px;
    min-height: 110px;
    flex-shrink: 0;
    background: #f5f5f5;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    align-self: center;
}
.proy-item-img img {
    max-width: 100%;
    max-height: 110px;
    object-fit: contain;
    padding: .5rem;
}

.proy-item-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: .2rem;
}
.proy-item-name {
    font-size: .95rem;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
    line-height: 1.35;
}
.proy-item-name:hover { color: #1a1a1a; text-decoration: underline; }
.proy-item-category {
    font-size: .85rem;
    color: #444;
}
.proy-item-time {
    font-size: .8rem;
    color: #aaa;
}
.proy-item-auth {
    display: flex;
    align-items: flex-start;
    gap: .4rem;
    margin-top: .5rem;
}
.proy-item-auth input[type="checkbox"] {
    margin-top: .15rem;
    accent-color: var(--rkl-primary);
    flex-shrink: 0;
    cursor: pointer;
}
.proy-item-auth label {
    font-size: .78rem;
    color: var(--rkl-primary);
    cursor: pointer;
    line-height: 1.4;
}

/* ── Comment ── */
.proy-item-comment-wrap {
    margin-top: .5rem;
}
.proy-item-comment-wrap textarea {
    width: 100%;
    font-size: .8rem;
    color: #444;
    border: 1px solid #e0e0e0;
    border-radius: 5px;
    padding: .4rem .6rem;
    resize: none;
    outline: none;
    line-height: 1.5;
    background: #fff;
    transition: border-color .15s;
}
.proy-item-comment-wrap textarea:focus { border-color: #bbb; }
.proy-item-comment-wrap textarea::placeholder { color: #bbb; }
.comment-status {
    font-size: .72rem;
    color: #aaa;
    text-align: right;
    min-height: 1.1em;
    margin-top: .15rem;
}

/* ── Similares toggle ── */
.proy-item-footer {
    display: flex;
    align-items: center;
    padding: .55rem 0;
    border-top: 1px solid #f0f0f0;
    margin-top: auto;
}
.btn-similares-toggle {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    background: none;
    border: 1px solid #d8d8d8;
    border-radius: 5px;
    padding: .3rem .75rem;
    font-size: .78rem;
    font-weight: 600;
    color: #555;
    cursor: pointer;
    transition: background .12s, border-color .12s, color .12s;
}
.btn-similares-toggle:hover { background: #f5f5f5; border-color: #bbb; }
.btn-similares-toggle.active {
    background: var(--rkl-primary);
    border-color: var(--rkl-primary);
    color: #fff;
}

/* ── Right panel ── */
.proy-item-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    gap: .75rem;
    flex-shrink: 0;
}
.proy-item-top-actions {
    display: flex;
    align-items: center;
    gap: .45rem;
}

/* ── Badge estado ── */
.badge-enstock {
    background: #1a1a1a;
    color: #fff;
    font-size: .72rem;
    font-weight: 500;
    padding: .3em .8em;
    border-radius: 3px;
    white-space: nowrap;
}

/* ── Btn quitar ── */
.btn-quitar-item {
    background: none;
    border: none;
    padding: .3rem .35rem;
    color: #888;
    cursor: pointer;
    border-radius: 4px;
    font-size: 1.1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color .15s, background .15s;
}
.btn-quitar-item:hover { color: #dc3545; background: #fde8e8; }

/* ── Qty control ── */
.qty-ctrl {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    overflow: hidden;
    height: 34px;
}
.qty-ctrl button {
    background: #f5f5f5;
    border: none;
    width: 34px;
    font-size: 1.1rem;
    font-weight: 600;
    color: #555;
    cursor: pointer;
    line-height: 1;
    transition: background .12s;
    display: flex;
    align-items: center;
    justify-content: center;
}
.qty-ctrl button:hover { background: #e8e8e8; }
.qty-ctrl input {
    border: none;
    border-left: 1px solid #d0d0d0;
    border-right: 1px solid #d0d0d0;
    width: 40px;
    text-align: center;
    font-weight: 600;
    font-size: .9rem;
    background: #fff;
    outline: none;
    box-shadow: none;
    -moz-appearance: textfield;
}
.qty-ctrl input::-webkit-outer-spin-button,
.qty-ctrl input::-webkit-inner-spin-button { -webkit-appearance: none; }

/* ── Sidebar ── */
.proyecto-sidebar .sidebar-card {
    background: #FAFAE8;
    border: 1px solid #E8E6C0;
    border-radius: 8px;
    padding: 1.25rem;
    position: sticky;
    top: 80px;
}
.sidebar-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 1rem;
}
.sidebar-items-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: .3rem;
}
.sidebar-items-label {
    font-size: .85rem;
    font-weight: 600;
    color: #1a1a1a;
}
.sidebar-items-count {
    font-size: .95rem;
    font-weight: 700;
    color: #1a1a1a;
}
.sidebar-time {
    font-size: .8rem;
    color: #888;
    margin-bottom: 1.1rem;
}
.btn-solicitar-sidebar {
    background: var(--rkl-primary);
    color: #fff;
    border: none;
    border-radius: 5px;
    padding: .7rem 1rem;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    width: 100%;
    text-align: center;
    transition: background .15s;
    display: block;
    margin-bottom: .75rem;
}
.btn-solicitar-sidebar:not(:disabled):hover { background: var(--rkl-primary-dark); }
.btn-solicitar-sidebar:disabled { opacity: .65; cursor: default; }
.sidebar-link {
    font-size: .85rem;
    color: #333;
    text-decoration: underline;
    text-align: center;
    display: block;
}
.sidebar-link:hover { color: #000; }

/* ── Similares panel ── */
.similares-panel {
    display: none;
    background: #f8f9fa;
    border: 1px solid #e9ecef;
    border-top: none;
    border-radius: 0 0 8px 8px;
    padding: 1rem 1.25rem 1.25rem;
    margin-top: -4px;
    margin-bottom: .85rem;
}
.similares-panel.open { display: block; }
.similares-panel-title {
    font-size: .78rem;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    letter-spacing: .5px;
    margin-bottom: .75rem;
}
.sim-card {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 6px;
    padding: .75rem;
    display: flex;
    gap: .75rem;
    align-items: center;
    height: 100%;
}
.sim-card-img {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    background: #f0f0f0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}
.sim-card-img img { max-width: 100%; max-height: 100%; object-fit: contain; padding: .25rem; }
.sim-card-body { flex: 1; min-width: 0; }
.sim-card-name {
    font-size: .8rem;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.35;
    margin-bottom: .3rem;
}
.sim-card-name:hover { text-decoration: underline; color: #1a1a1a; }
.sim-card-desc {
    font-size: .73rem;
    color: #888;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: .4rem;
}
.btn-sim-agregar {
    font-size: .73rem;
    font-weight: 600;
    padding: .2rem .55rem;
    background: #2C3E50;
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    white-space: nowrap;
    transition: background .12s;
}
.btn-sim-agregar:hover { background: #3d5166; }
</style>
{% endblock %}

{% block body %}

{# Cabecera #}
<h4 class="fw-bold mb-1" style="color:#1a1a1a;">{{ proyecto.nombre }}</h4>

{% if proyecto.items is empty %}

<div class="text-center py-5">
    <i class="ri-shopping-bag-line" style="font-size:3rem;color:#ccc;"></i>
    <h5 class="text-muted mt-3">El proyecto está vacío</h5>
    <p class="text-muted small mb-4">Agregá productos desde el catálogo para armar tu pedido.</p>
    <a href="{{ path('app_catalogo_lista') }}" class="btn btn-warning fw-semibold px-4">
        <i class="ri-store-2-line me-1"></i> Ir al catálogo
    </a>
</div>

{% else %}

<p class="text-muted mb-3" style="font-size:.9rem;">Listado de productos</p>

<div class="proyecto-layout">

    {# ── Lista de items ── #}
    <div class="proyecto-items" id="lista-items">
        {% for item in proyecto.items %}

        <div class="proy-item-card" data-item-id="{{ item.id }}">

            {# Fila principal: imagen | contenido | panel derecho #}
            <div class="proy-item-main">

                {# Imagen #}
                <div class="proy-item-img">
                    {% if item.articulo.imagen %}
                    <img src="{{ item.articulo.imagen }}" alt="{{ item.articulo.nombreDisplay }}"
                         onerror="this.style.display='none';this.closest('.proy-item-img').innerHTML='<i class=\'ri-image-line\' style=\'color:#ccc;font-size:2rem;\'></i>'">
                    {% else %}
                    <i class="ri-image-line" style="color:#ccc;font-size:2rem;"></i>
                    {% endif %}
                </div>

                {# Contenido principal #}
                <div class="proy-item-body">
                    <a href="{{ path('app_catalogo_detalle', {codigo: item.articulo.codigoCalipso}) }}"
                       class="proy-item-name">{{ item.articulo.nombreDisplay }}</a>

                    {% if item.articulo.descripcion %}
                    <span class="proy-item-category">{{ item.articulo.descripcion|slice(0,60) }}{% if item.articulo.descripcion|length > 60 %}…{% endif %}</span>
                    {% endif %}

                    {% if item.articulo.bu %}
                    <span class="proy-item-time">{{ item.articulo.bu }}</span>
                    {% endif %}

                    {# Comentario #}
                    <div class="proy-item-comment-wrap">
                        <textarea rows="2"
                                  class="input-item-comment"
                                  placeholder="Comentario (opcional)…"
                                  data-item="{{ item.id }}">{{ item.comment }}</textarea>
                        <div class="comment-status" data-item="{{ item.id }}"></div>
                    </div>

                    {# Autorización de reemplazo #}
                    <div class="proy-item-auth">
                        <input type="checkbox" id="auth-{{ item.id }}" class="input-item-auth" data-item="{{ item.id }}">
                        <label for="auth-{{ item.id }}">
                            Autorizo el reemplazo por un producto similar en caso de falta de stock.
                        </label>
                    </div>
                </div>

                {# Panel derecho: badge + quitar | qty #}
                <div class="proy-item-right">
                    <div class="proy-item-top-actions">
                        <span class="badge-enstock">En Stock</span>
                        <button class="btn-quitar-item" data-item="{{ item.id }}"
                                data-nombre="{{ item.articulo.nombreDisplay|e('html_attr') }}"
                                title="Quitar del proyecto">
                            <i class="ri-delete-bin-line"></i>
                        </button>
                    </div>
                    <div class="qty-ctrl">
                        <button type="button" class="btn-item-menos" data-item="{{ item.id }}">−</button>
                        <input type="number" class="input-item-cantidad"
                               value="{{ item.cantidad }}" min="1" max="999"
                               data-item="{{ item.id }}">
                        <button type="button" class="btn-item-mas" data-item="{{ item.id }}">+</button>
                    </div>
                </div>

            </div>{# /.proy-item-main #}

            {# Footer: botón productos similares #}
            <div class="proy-item-footer">
                <button type="button"
                        class="btn-similares-toggle"
                        data-codigo="{{ item.articulo.codigoCalipso }}"
                        data-panel="similares-{{ item.id }}">
                    <i class="ri-stack-line btn-sim-icon"></i>
                    <span class="btn-sim-text">Productos similares</span>
                </button>
            </div>

        </div>{# /.proy-item-card #}

        {# Panel similares (se abre bajo la card) #}
        <div class="similares-panel" id="similares-{{ item.id }}" data-loaded="false">
            <div class="similares-panel-title">Productos similares</div>
            <div class="similares-grid row g-2"></div>
        </div>

        {% endfor %}
    </div>

    {# ── Sidebar Solicitud ── #}
    <div class="proyecto-sidebar">
        <div class="sidebar-card">
            <div class="sidebar-title">Solicitud</div>

            <div class="sidebar-items-row">
                <span class="sidebar-items-label">Cantidad de items a cotizar</span>
                <span class="sidebar-items-count" id="sidebar-items-count">{{ proyecto.cantidadProductos }}</span>
            </div>
            <div class="sidebar-time">Tiempo de espera: a confirmar</div>

            <button type="button" class="btn-solicitar-sidebar"
                    id="btn-solicitar-pedido"
                    onclick="RKL.clarity('event','solicitar_pedido');RKL.clarity('set','proyecto_cotizado','{{ proyecto.id }}');"
                    {% if proyecto.cantidadProductos == 0 %}disabled{% endif %}>
                Solicitar Cotización
            </button>

            <a href="{{ path('app_catalogo_lista') }}" class="sidebar-link">
                Seguir sumando productos
            </a>
        </div>
    </div>

</div>

{% endif %}

{# ── Modal: confirmar eliminación de item ── #}
<div class="modal fade" id="modalEliminarItem" tabindex="-1" aria-labelledby="modalEliminarItemLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content" style="border-radius:12px;border:none;box-shadow:0 8px 32px rgba(0,0,0,.15);">
            <div class="modal-body p-4 text-center">
                <div style="width:60px;height:60px;background:#fde8e8;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem;">
                    <i class="ri-delete-bin-line" style="font-size:1.6rem;color:#e05252;"></i>
                </div>
                <h5 class="fw-bold mb-2" style="font-size:1.05rem;">¿Quitar producto?</h5>
                <p class="mb-1" style="font-size:.9rem;color:#444;">
                    <span id="modal-item-nombre" class="fw-semibold"></span>
                    <span class="text-muted"> será eliminado del proyecto.</span>
                </p>
                <p class="text-muted mb-0" style="font-size:.8rem;">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4 px-4 gap-2 justify-content-center">
                <button type="button" class="btn btn-outline-secondary px-4 fw-semibold" data-bs-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn px-4 fw-semibold" id="btn-confirmar-eliminar-item"
                        style="background:#dc3545;color:#fff;">
                    <i class="ri-delete-bin-line me-1"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block extra_js %}
<script>
(function () {

    // ── Actualizar cantidad vía AJAX ──
    async function actualizarCantidad(itemId, cantidad) {
        const fd = new FormData();
        fd.append('cantidad', cantidad);
        await fetch(`/secure/proyectos/item/${itemId}/cantidad`, { method: 'POST', body: fd });
    }

    // ── Modal eliminar item ──
    let pendingDeleteId = null;
    const _modalEl = document.getElementById('modalEliminarItem');
    const _bsModal = bootstrap.Modal.getOrCreateInstance(_modalEl);

    function abrirModalEliminar(id) {
        const card   = document.querySelector(`.proy-item-card[data-item-id="${id}"]`);
        const btn    = card ? card.querySelector('.btn-quitar-item') : null;
        const nombre = btn ? btn.dataset.nombre : 'Este producto';
        pendingDeleteId = id;
        document.getElementById('modal-item-nombre').textContent = nombre;
        _bsModal.show();
    }

    document.getElementById('btn-confirmar-eliminar-item').addEventListener('click', async function () {
        if (!pendingDeleteId) return;
        const id = pendingDeleteId;
        pendingDeleteId = null;
        _bsModal.hide();
        const fd  = new FormData();
        const res = await fetch(`/secure/proyectos/item/${id}/quitar`, { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) {
            const card  = document.querySelector(`.proy-item-card[data-item-id="${id}"]`);
            if (card) card.remove();
            const simPanel = document.getElementById(`similares-${id}`);
            if (simPanel) simPanel.remove();
            actualizarSidebar();
            if (!document.querySelector('.proy-item-card')) location.reload();
        }
    });

    // ── Botones − ──
    document.querySelectorAll('.btn-item-menos').forEach(btn => {
        btn.addEventListener('click', function () {
            const id    = this.dataset.item;
            const input = document.querySelector(`.input-item-cantidad[data-item="${id}"]`);
            const val   = parseInt(input.value);
            if (val > 1) {
                input.value = val - 1;
                actualizarCantidad(id, input.value);
            } else {
                abrirModalEliminar(id);
            }
        });
    });

    // ── Botones + ──
    document.querySelectorAll('.btn-item-mas').forEach(btn => {
        btn.addEventListener('click', function () {
            const id    = this.dataset.item;
            const input = document.querySelector(`.input-item-cantidad[data-item="${id}"]`);
            const val   = parseInt(input.value);
            if (val < 999) {
                input.value = val + 1;
                actualizarCantidad(id, input.value);
            }
        });
    });

    // ── Cambio manual de input ──
    document.querySelectorAll('.input-item-cantidad').forEach(input => {
        input.addEventListener('change', function () {
            const v = Math.max(1, Math.min(999, parseInt(this.value) || 1));
            this.value = v;
            actualizarCantidad(this.dataset.item, v);
        });
    });

    // ── Quitar item ──
    document.querySelectorAll('.btn-quitar-item').forEach(btn => {
        btn.addEventListener('click', function () {
            abrirModalEliminar(this.dataset.item);
        });
    });

    // ── Actualizar sidebar (contador) ──
    function actualizarSidebar() {
        const n = document.querySelectorAll('.proy-item-card').length;
        const countEl = document.getElementById('sidebar-items-count');
        if (countEl) countEl.textContent = n;
        const btnPedido = document.getElementById('btn-solicitar-pedido');
        if (btnPedido) btnPedido.disabled = n === 0;
    }

    // ── Productos similares ──
    function renderSimilares(grid, items) {
        if (!items.length) {
            grid.innerHTML = '<p class="text-muted small mb-0">No se encontraron productos similares.</p>';
            return;
        }
        grid.innerHTML = items.map(a => `
            <div class="col-6 col-lg-3">
                <div class="sim-card">
                    <div class="sim-card-img">
                        ${a.imagen
                            ? `<img src="${a.imagen}" alt="" onerror="this.style.display='none'">`
                            : `<i class="ri-image-line" style="color:#ccc;font-size:1.2rem;"></i>`}
                    </div>
                    <div class="sim-card-body">
                        <a href="/catalogo/productos/${encodeURIComponent(a.codigo)}" class="sim-card-name"
                           onclick="RKL.clarity('event','similar_click');RKL.clarity('set','similar_clickeado',${JSON.stringify(a.codigo)});">${a.nombre}</a>
                        ${a.descripcion ? `<div class="sim-card-desc">${a.descripcion}</div>` : ''}
                        <button type="button" class="btn-sim-agregar btn-agregar-proyecto"
                                data-articulo-codigo="${a.codigo}"
                                data-articulo-nombre="${a.nombre.replace(/"/g, '&quot;')}">
                            + Agregar
                        </button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    document.querySelectorAll('.btn-similares-toggle').forEach(btn => {
        btn.addEventListener('click', async function () {
            const panelId = this.dataset.panel;
            const codigo  = this.dataset.codigo;
            const panel   = document.getElementById(panelId);
            const grid    = panel.querySelector('.similares-grid');
            const isOpen  = panel.classList.contains('open');
            const iconEl  = this.querySelector('.btn-sim-icon');
            const textEl  = this.querySelector('.btn-sim-text');

            if (isOpen) {
                panel.classList.remove('open');
                this.classList.remove('active');
                if (iconEl) iconEl.className = 'ri-stack-line btn-sim-icon';
                if (textEl) textEl.textContent = 'Productos similares';
                return;
            }

            panel.classList.add('open');
            this.classList.add('active');
            if (iconEl) iconEl.className = 'ri-close-line btn-sim-icon';
            if (textEl) textEl.textContent = 'Cerrar similares';
            RKL.clarity('event', 'similares_abierto');
            RKL.clarity('set', 'similares_de', codigo);

            if (panel.dataset.loaded === 'true') return;

            grid.innerHTML = '<div class="text-muted small py-2"><i class="ri-loader-4-line me-1"></i> Cargando…</div>';

            try {
                const res  = await fetch(`/catalogo/productos/${encodeURIComponent(codigo)}/similares`);
                const data = await res.json();
                panel.dataset.loaded = 'true';
                renderSimilares(grid, data);
            } catch {
                grid.innerHTML = '<p class="text-muted small mb-0">Error al cargar productos similares.</p>';
            }
        });
    });

    // ── Guardar comentario vía AJAX ──
    let commentTimers = {};
    document.querySelectorAll('.input-item-comment').forEach(ta => {
        ta.addEventListener('input', function () {
            const id     = this.dataset.item;
            const status = document.querySelector(`.comment-status[data-item="${id}"]`);
            clearTimeout(commentTimers[id]);
            if (status) status.textContent = 'Escribiendo…';
            commentTimers[id] = setTimeout(async () => {
                const fd = new FormData();
                fd.append('comment', this.value);
                try {
                    const res  = await fetch(`/secure/proyectos/item/${id}/comment`, { method: 'POST', body: fd });
                    const data = await res.json();
                    if (status) status.textContent = data.success ? 'Guardado ✓' : 'Error al guardar';
                    if (data.success) setTimeout(() => { if (status) status.textContent = ''; }, 2000);
                } catch {
                    if (status) status.textContent = 'Error al guardar';
                }
            }, 700);
        });
    });

})();
</script>
{% endblock %}
