{% extends 'base.html.twig' %}

{% block title %}{{ proyecto.nombre }}{% endblock %}

{% block body %}
<div class="container-fluid">

    <div class="row">
        <div class="col-12">
            <div class="page-title-box d-sm-flex align-items-center justify-content-between bg-galaxy-transparent">
                <h4 class="mb-0">{{ proyecto.nombre }}</h4>
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="#">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('app_proyectos_index') }}">Proyectos</a></li>
                        <li class="breadcrumb-item active">{{ proyecto.nombre }}</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endfor %}
    {% endfor %}

    {# Header del proyecto #}
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    {% if proyecto.descripcion %}
                    <p class="text-muted mb-1">{{ proyecto.descripcion }}</p>
                    {% endif %}
                    <div class="d-flex gap-3 small text-muted">
                        <span><i class="ri-calendar-line me-1"></i>Creado el {{ proyecto.createdAt|date('d/m/Y') }}</span>
                        <span><i class="ri-shopping-bag-line me-1"></i>{{ proyecto.cantidadProductos }} producto{{ proyecto.cantidadProductos != 1 ? 's' : '' }}</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <a href="{{ path('app_catalogo_lista') }}" class="btn btn-outline-warning btn-sm">
                        <i class="ri-add-line me-1"></i> Agregar productos
                    </a>
                    <a href="{{ path('app_proyectos_editar', {id: proyecto.id}) }}" class="btn btn-light btn-sm">
                        <i class="ri-edit-line me-1"></i> Editar
                    </a>
                    <button type="button" class="btn btn-warning btn-sm fw-semibold" disabled>
                        Solicitar cotización
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# Lista de items #}
    {% if proyecto.items is empty %}
    <div class="text-center py-5">
        <i class="ri-shopping-bag-line fs-1 text-muted"></i>
        <h5 class="text-muted mt-3">El proyecto está vacío</h5>
        <p class="text-muted small">Agregá productos desde el catálogo.</p>
        <a href="{{ path('app_catalogo_lista') }}" class="btn btn-warning mt-2">
            <i class="ri-store-2-line me-1"></i> Ir al catálogo
        </a>
    </div>
    {% else %}
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width:60px;"></th>
                            <th>Producto</th>
                            <th>Código</th>
                            <th class="text-center" style="width:150px;">Cantidad</th>
                            <th style="width:60px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in proyecto.items %}
                        <tr data-item-id="{{ item.id }}">
                            <td class="ps-4">
                                {% if item.articulo.imagen %}
                                <img src="{{ item.articulo.imagen }}" alt=""
                                     style="width:48px;height:48px;object-fit:contain;"
                                     onerror="this.style.display='none'">
                                {% else %}
                                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                     style="width:48px;height:48px;">
                                    <i class="ri-image-line text-muted"></i>
                                </div>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_catalogo_detalle', {codigo: item.articulo.codigoCalipso}) }}"
                                   class="text-dark fw-semibold text-decoration-none">
                                    {{ item.articulo.nombreDisplay }}
                                </a>
                                {% if item.articulo.categoriaAdvisor %}
                                <br><small class="text-muted">{{ item.articulo.categoriaAdvisor }}{% if item.articulo.subcategoriaAdvisor %} › {{ item.articulo.subcategoriaAdvisor }}{% endif %}</small>
                                {% endif %}
                            </td>
                            <td class="text-muted small">{{ item.articulo.codigoRockwell ?? item.articulo.codigoCalipso }}</td>
                            <td class="text-center">
                                <div class="input-group input-group-sm justify-content-center" style="max-width:120px;margin:0 auto;">
                                    <button class="btn btn-outline-secondary btn-cantidad-menos" data-item="{{ item.id }}" type="button">-</button>
                                    <input type="number" class="form-control text-center input-cantidad"
                                           value="{{ item.cantidad }}" min="1" max="999"
                                           data-item="{{ item.id }}" style="max-width:50px;">
                                    <button class="btn btn-outline-secondary btn-cantidad-mas" data-item="{{ item.id }}" type="button">+</button>
                                </div>
                            </td>
                            <td class="text-end pe-3">
                                <button class="btn btn-sm btn-outline-danger btn-quitar-item" data-item="{{ item.id }}"
                                        title="Quitar del proyecto">
                                    <i class="ri-close-line"></i>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function() {
    // Actualizar cantidad
    async function actualizarCantidad(itemId, cantidad) {
        const fd = new FormData();
        fd.append('cantidad', cantidad);
        await fetch(`/secure/proyectos/item/${itemId}/cantidad`, {method: 'POST', body: fd});
    }

    document.querySelectorAll('.btn-cantidad-menos').forEach(btn => {
        btn.addEventListener('click', function() {
            const id = this.dataset.item;
            const input = document.querySelector(`.input-cantidad[data-item="${id}"]`);
            if (parseInt(input.value) > 1) {
                input.value = parseInt(input.value) - 1;
                actualizarCantidad(id, input.value);
            }
        });
    });

    document.querySelectorAll('.btn-cantidad-mas').forEach(btn => {
        btn.addEventListener('click', function() {
            const id = this.dataset.item;
            const input = document.querySelector(`.input-cantidad[data-item="${id}"]`);
            if (parseInt(input.value) < 999) {
                input.value = parseInt(input.value) + 1;
                actualizarCantidad(id, input.value);
            }
        });
    });

    document.querySelectorAll('.input-cantidad').forEach(input => {
        input.addEventListener('change', function() {
            actualizarCantidad(this.dataset.item, this.value);
        });
    });

    // Quitar item
    document.querySelectorAll('.btn-quitar-item').forEach(btn => {
        btn.addEventListener('click', async function() {
            if (!confirm('¿Quitar este producto del proyecto?')) return;
            const id = this.dataset.item;
            const fd = new FormData();
            const response = await fetch(`/secure/proyectos/item/${id}/quitar`, {method: 'POST', body: fd});
            const data = await response.json();
            if (data.success) {
                document.querySelector(`tr[data-item-id="${id}"]`)?.remove();
            }
        });
    });
})();
</script>
{% endblock %}
