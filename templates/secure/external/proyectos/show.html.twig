{% extends 'base_catalogo.html.twig' %}

{% block title %}{{ proyecto.nombre }}{% endblock %}

{% block breadcrumb %}
<ol class="breadcrumb mb-0">
    <li class="breadcrumb-item">
        <a href="{{ path('app_proyectos_index') }}">Proyectos</a>
    </li>
    <li class="breadcrumb-item active">{{ proyecto.nombre|slice(0,40) }}{% if proyecto.nombre|length > 40 %}…{% endif %}</li>
</ol>
{% endblock %}

{% block stylesheets %}
<style>
/* ── Layout ── */
.proyecto-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 1.5rem;
    align-items: start;
}
@media (max-width: 991px) {
    .proyecto-layout { grid-template-columns: 1fr; }
    .proyecto-sidebar { order: -1; }
}

/* ── Item card ── */
.proy-item-card {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    padding: 1.25rem 1.5rem 1.25rem 1.25rem;
    display: flex;
    gap: 1.25rem;
    align-items: stretch;
    margin-bottom: 1rem;
    position: relative;
}
.proy-item-img {
    width: 140px;
    min-height: 140px;
    flex-shrink: 0;
    background: #f0f0f0;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}
.proy-item-img img {
    max-width: 100%;
    max-height: 140px;
    object-fit: contain;
    padding: .6rem;
}
.proy-item-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
}
.proy-item-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .75rem;
    margin-bottom: .4rem;
    margin-right:1rem;
}
.proy-item-name {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
    line-height: 1.35;
}
.proy-item-name:hover { color: #1a1a1a; text-decoration: underline; }
.proy-item-desc {
    font-size: .85rem;
    color: #555;
    margin-bottom: .35rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.55;
}
.proy-item-meta {
    font-size: .82rem;
    color: #999;
    margin-bottom: .5rem;
}
.proy-item-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: .5rem;
    margin-top: auto;
    padding-top: .75rem;
    border-top: 1px solid #f3f3f3;
}

/* ── Badge estado ── */
.badge-enstock {
    background: #333;
    color: #fff;
    font-size: .72rem;
    font-weight: 500;
    padding: .3em .75em;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
}
.badge-nuevo {
    background: var(--rkl-primary, #ACA300);
    color: #fff;
    font-size: .72rem;
    font-weight: 500;
    padding: .3em .75em;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
}

/* ── Qty control ── */
.qty-ctrl {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    overflow: hidden;
    height: 34px;
}
.qty-ctrl button {
    background: #f5f5f5;
    border: none;
    width: 34px;
    font-size: 1.1rem;
    font-weight: 600;
    color: #333;
    cursor: pointer;
    line-height: 1;
    transition: background .12s;
    display: flex;
    align-items: center;
    justify-content: center;
}
.qty-ctrl button:hover { background: #e8e8e8; }
.qty-ctrl input {
    border: none;
    border-left: 1px solid #d0d0d0;
    border-right: 1px solid #d0d0d0;
    width: 48px;
    text-align: center;
    font-weight: 600;
    font-size: .9rem;
    background: #fff;
    outline: none;
    box-shadow: none;
    -moz-appearance: textfield;
}
.qty-ctrl input::-webkit-outer-spin-button,
.qty-ctrl input::-webkit-inner-spin-button { -webkit-appearance: none; }

.qty-label {
    font-size: .8rem;
    font-weight: 600;
    color: #555;
    text-transform: uppercase;
    letter-spacing: .4px;
    margin-right: .6rem;
    line-height: 34px;
}

/* ── Btn quitar ── */
.btn-quitar-item {
    position: absolute;
    top: .6rem;
    right: .6rem;
    background: #fde8e8;
    border: none;
    padding: .25rem .35rem;
    color: #e05252;
    cursor: pointer;
    border-radius: 4px;
    font-size: 1rem;
    line-height: 1;
    transition: background .15s, color .15s;
    display: flex;
    align-items: center;
    justify-content: center;
}
.btn-quitar-item:hover { background: #dc3545; color: #fff; }

/* ── Panel similares ── */
.similares-panel {
    display: none;
    background: #f8f9fa;
    border: 1px solid #e9ecef;
    border-top: none;
    border-radius: 0 0 8px 8px;
    padding: 1rem 1.25rem 1.25rem;
    margin-top: -4px;
    margin-bottom: 1rem;
}
.similares-panel.open { display: block; }
.similares-panel-title {
    font-size: .78rem;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    letter-spacing: .5px;
    margin-bottom: .75rem;
}
.sim-card {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 6px;
    padding: .75rem;
    display: flex;
    gap: .75rem;
    align-items: center;
    height: 100%;
}
.sim-card-img {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    background: #f0f0f0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}
.sim-card-img img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    padding: .25rem;
}
.sim-card-body {
    flex: 1;
    min-width: 0;
}
.sim-card-name {
    font-size: .8rem;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.35;
    margin-bottom: .3rem;
}
.sim-card-name:hover { text-decoration: underline; color: #1a1a1a; }
.sim-card-desc {
    font-size: .73rem;
    color: #888;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: .4rem;
}
.btn-sim-agregar {
    font-size: .73rem;
    font-weight: 600;
    padding: .2rem .55rem;
    background: #2C3E50;
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    white-space: nowrap;
    transition: background .12s;
}
.btn-sim-agregar:hover { background: #3d5166; }
.btn-similares-toggle {
    font-size: .78rem;
    font-weight: 600;
    padding: .2rem .6rem;
    background: none;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    color: #555;
    cursor: pointer;
    transition: background .12s, border-color .12s;
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    white-space: nowrap;
}
.btn-similares-toggle:hover { background: #f5f5f5; border-color: #bbb; }
.btn-similares-toggle.active { background: #2C3E50; color: #fff; border-color: #2C3E50; }

/* ── Sidebar ── */
.proyecto-sidebar .card {
    border: 1px solid #e9ecef;
    border-radius: 8px;
    position: sticky;
    top: 80px;
}
.sidebar-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: .5rem 0;
    border-bottom: 1px solid #f0f0f0;
    font-size: .85rem;
}
.sidebar-row:last-of-type { border-bottom: none; }
.sidebar-total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: .6rem 0;
    font-size: 1rem;
    font-weight: 700;
}
.sidebar-meta {
    font-size: .78rem;
    color: #888;
    margin-top: .25rem;
}
.price-strike {
    text-decoration: line-through;
    color: #bbb;
    font-size: .82rem;
    margin-right: .3rem;
}
.price-real {
    color: #1a1a1a;
    font-weight: 600;
}
</style>
{% endblock %}

{% block body %}

{# Cabecera del proyecto #}
<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="color:#1a1a1a;">{{ proyecto.nombre }}</h4>
        {% if proyecto.descripcion %}
        <p class="text-muted mb-0" style="font-size:.875rem;">{{ proyecto.descripcion }}</p>
        {% endif %}
    </div>
    <div class="d-flex gap-2 flex-shrink-0">
        <a href="{{ path('app_proyectos_editar', {id: proyecto.id}) }}"
           class="btn fw-semibold py-2 px-3"
           style="background:#6c757d;color:#fff;border-radius:6px;font-size:.9rem;">
            <i class="ri-edit-line me-1"></i> Editar
        </a>
        <form method="POST" action="{{ path('app_proyectos_eliminar', {id: proyecto.id}) }}"
              onsubmit="return confirm('¿Eliminar el proyecto « {{ proyecto.nombre|e('js') }} »? Esta acción no se puede deshacer.');">
            <input type="hidden" name="_token" value="{{ csrf_token('proyecto_eliminar_' ~ proyecto.id) }}">
            <button type="submit" class="btn fw-semibold py-2 px-3"
                    style="background:#dc3545;color:#fff;border-radius:6px;font-size:.9rem;">
                <i class="ri-delete-bin-line me-1"></i> Eliminar
            </button>
        </form>
    </div>
</div>

{% if proyecto.items is empty %}

<div class="text-center py-5">
    <i class="ri-shopping-bag-line" style="font-size:3rem;color:#ccc;"></i>
    <h5 class="text-muted mt-3">El proyecto está vacío</h5>
    <p class="text-muted small mb-4">Agregá productos desde el catálogo para armar tu pedido.</p>
    <a href="{{ path('app_catalogo_lista') }}" class="btn btn-warning fw-semibold px-4">
        <i class="ri-store-2-line me-1"></i> Ir al catálogo
    </a>
</div>

{% else %}

<div class="proyecto-layout">

    {# ── Lista de items ── #}
    <div class="proyecto-items" id="lista-items">
        {% for item in proyecto.items %}
        <div class="proy-item-card" data-item-id="{{ item.id }}">
            {# Botón quitar — esquina superior derecha #}
            <button class="btn-quitar-item" data-item="{{ item.id }}"
                    data-nombre="{{ item.articulo.nombreDisplay|e('html_attr') }}"
                    title="Quitar del proyecto">
                <i class="ri-close-line"></i>
            </button>


            {# Imagen #}
            <div class="proy-item-img">
                {% if item.articulo.imagen %}
                <img src="{{ item.articulo.imagen }}" alt="{{ item.articulo.nombreDisplay }}"
                     onerror="this.style.display='none';this.closest('.proy-item-img').innerHTML='<i class=\'ri-image-line\' style=\'color:#ccc;font-size:2rem;\'></i>'">
                {% else %}
                <i class="ri-image-line" style="color:#ccc;font-size:2rem;"></i>
                {% endif %}
            </div>

            {# Contenido #}
            <div class="proy-item-body">

                {# Nombre + badge de stock — sin overlap #}
                <div class="proy-item-header ml-5">
                    <a href="{{ path('app_catalogo_detalle', {codigo: item.articulo.codigoCalipso}) }}"
                       class="proy-item-name">{{ item.articulo.nombreDisplay }}</a>
                    <span class="badge-enstock">En Stock</span>
                </div>

                {% if item.articulo.descripcion %}
                <p class="proy-item-desc">{{ item.articulo.descripcion }}</p>
                {% endif %}

                {% if item.articulo.codigoRockwell %}
                <div class="proy-item-meta">Cód: {{ item.articulo.codigoRockwell }}</div>
                {% endif %}

                {# Comentario libre #}
                <div class="proy-item-comment mt-2 mb-1">
                    <textarea class="input-item-comment form-control form-control-sm proy-item-desc"
                              rows="2"
                              placeholder="Comentario (opcional)…"
                              data-item="{{ item.id }}"
                              style="font-size:.82rem;resize:vertical;border-color:#e0e0e0;">{{ item.comment }}</textarea>
                    <div class="comment-status" data-item="{{ item.id }}" style="font-size:.75rem;color:#999;text-align:right;min-height:1.2em;"></div>
                </div>

                {# Footer: cantidad | similares | X #}
                <div class="proy-item-footer">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="qty-label">Cantidad</span>
                        <div class="qty-ctrl">
                            <button type="button" class="btn-item-menos" data-item="{{ item.id }}">−</button>
                            <input type="number" class="input-item-cantidad"
                                   value="{{ item.cantidad }}" min="1" max="999"
                                   data-item="{{ item.id }}">
                            <button type="button" class="btn-item-mas" data-item="{{ item.id }}">+</button>
                        </div>
                        <button type="button"
                                class="btn-similares-toggle"
                                data-codigo="{{ item.articulo.codigoCalipso }}"
                                data-panel="similares-{{ item.id }}">
                            <i class="ri-stack-line btn-sim-icon"></i>
                            <span class="btn-sim-text">Productos similares</span>
                        </button>
                    </div>
                </div>

            </div>
        </div>

        {# Panel similares (se abre bajo la card) #}
        <div class="similares-panel" id="similares-{{ item.id }}" data-loaded="false">
            <div class="similares-panel-title">Productos similares</div>
            <div class="similares-grid row g-2"></div>
        </div>
        {% endfor %}

    </div>

    {# ── Sidebar resumen ── #}
    <div class="proyecto-sidebar">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3">

                <div class="sidebar-row">
                    <span class="text-muted">Subtotal</span>
                    <span class="fw-semibold" id="sidebar-subtotal-label">
                        {{ proyecto.cantidadProductos }} producto{{ proyecto.cantidadProductos != 1 ? 's' : '' }}
                    </span>
                </div>

                <div class="sidebar-total-row mt-2">
                    <span>TOTAL</span>
                    <span id="sidebar-total-items">{{ proyecto.cantidadProductos }} ítem{{ proyecto.cantidadProductos != 1 ? 's' : '' }}</span>
                </div>

                <div class="sidebar-meta mb-3">
                    <i class="ri-time-line me-1"></i> Sujeto a disponibilidad de stock
                </div>

                <button type="button" class="btn w-100 fw-semibold py-2"
                        style="background:#2C3E50;color:#fff;border-radius:6px;font-size:.9rem;"
                        id="btn-solicitar-pedido"
                        {% if proyecto.cantidadProductos == 0 %}disabled{% endif %}>
                    Solicitar pedido
                </button>

            </div>
        </div>

    </div>

</div>

{% endif %}

{# ── Modal: confirmar eliminación de item ── #}
<div class="modal fade" id="modalEliminarItem" tabindex="-1" aria-labelledby="modalEliminarItemLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content" style="border-radius:12px;border:none;box-shadow:0 8px 32px rgba(0,0,0,.15);">
            <div class="modal-body p-4 text-center">
                <div style="width:60px;height:60px;background:#fde8e8;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem;">
                    <i class="ri-delete-bin-line" style="font-size:1.6rem;color:#e05252;"></i>
                </div>
                <h5 class="fw-bold mb-2" style="font-size:1.05rem;">¿Quitar producto?</h5>
                <p class="mb-1" style="font-size:.9rem;color:#444;">
                    <span id="modal-item-nombre" class="fw-semibold"></span>
                    <span class="text-muted"> será eliminado del proyecto.</span>
                </p>
                <p class="text-muted mb-0" style="font-size:.8rem;">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4 px-4 gap-2 justify-content-center">
                <button type="button" class="btn btn-outline-secondary px-4 fw-semibold" data-bs-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn px-4 fw-semibold" id="btn-confirmar-eliminar-item"
                        style="background:#dc3545;color:#fff;">
                    <i class="ri-delete-bin-line me-1"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block extra_js %}
<script>
(function () {

    // ── Actualizar cantidad vía AJAX ──
    async function actualizarCantidad(itemId, cantidad) {
        const fd = new FormData();
        fd.append('cantidad', cantidad);
        await fetch(`/secure/proyectos/item/${itemId}/cantidad`, { method: 'POST', body: fd });
    }

    // ── Modal eliminar item ──
    let pendingDeleteId = null;
    const _modalEl = document.getElementById('modalEliminarItem');
    const _bsModal = bootstrap.Modal.getOrCreateInstance(_modalEl);

    function abrirModalEliminar(id) {
        const card   = document.querySelector(`.proy-item-card[data-item-id="${id}"]`);
        const btn    = card ? card.querySelector('.btn-quitar-item') : null;
        const nombre = btn ? btn.dataset.nombre : 'Este producto';
        pendingDeleteId = id;
        document.getElementById('modal-item-nombre').textContent = nombre;
        _bsModal.show();
    }

    document.getElementById('btn-confirmar-eliminar-item').addEventListener('click', async function () {
        if (!pendingDeleteId) return;
        const id = pendingDeleteId;
        pendingDeleteId = null;
        _bsModal.hide();
        const fd  = new FormData();
        const res = await fetch(`/secure/proyectos/item/${id}/quitar`, { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) {
            const card  = document.querySelector(`.proy-item-card[data-item-id="${id}"]`);
            if (card) card.remove();
            const simPanel = document.getElementById(`similares-${id}`);
            if (simPanel) simPanel.remove();
            actualizarSidebar();
            if (!document.querySelector('.proy-item-card')) location.reload();
        }
    });

    // ── Botones − ──
    document.querySelectorAll('.btn-item-menos').forEach(btn => {
        btn.addEventListener('click', function () {
            const id    = this.dataset.item;
            const input = document.querySelector(`.input-item-cantidad[data-item="${id}"]`);
            const val   = parseInt(input.value);
            if (val > 1) {
                input.value = val - 1;
                actualizarCantidad(id, input.value);
            } else {
                // Cantidad es 1 → preguntar si quitar el producto
                abrirModalEliminar(id);
            }
        });
    });

    // ── Botones + ──
    document.querySelectorAll('.btn-item-mas').forEach(btn => {
        btn.addEventListener('click', function () {
            const id    = this.dataset.item;
            const input = document.querySelector(`.input-item-cantidad[data-item="${id}"]`);
            const val   = parseInt(input.value);
            if (val < 999) {
                input.value = val + 1;
                actualizarCantidad(id, input.value);
            }
        });
    });

    // ── Cambio manual de input ──
    document.querySelectorAll('.input-item-cantidad').forEach(input => {
        input.addEventListener('change', function () {
            const v = Math.max(1, Math.min(999, parseInt(this.value) || 1));
            this.value = v;
            actualizarCantidad(this.dataset.item, v);
        });
    });

    // ── Quitar item ──
    document.querySelectorAll('.btn-quitar-item').forEach(btn => {
        btn.addEventListener('click', function () {
            abrirModalEliminar(this.dataset.item);
        });
    });

    // ── Actualizar sidebar (contador) ──
    function actualizarSidebar() {
        const cards = document.querySelectorAll('.proy-item-card');
        const n = cards.length;
        const labelS = document.getElementById('sidebar-subtotal-label');
        const labelT = document.getElementById('sidebar-total-items');
        if (labelS) labelS.textContent = n + ' producto' + (n !== 1 ? 's' : '');
        if (labelT) labelT.textContent = n + ' ítem'     + (n !== 1 ? 's' : '');
        const btnPedido = document.getElementById('btn-solicitar-pedido');
        if (btnPedido) btnPedido.disabled = n === 0;
    }

    // ── Productos similares ──
    function renderSimilares(grid, items) {
        if (!items.length) {
            grid.innerHTML = '<p class="text-muted small mb-0">No se encontraron productos similares.</p>';
            return;
        }
        grid.innerHTML = items.map(a => `
            <div class="col-6 col-lg-3">
                <div class="sim-card">
                    <div class="sim-card-img">
                        ${a.imagen
                            ? `<img src="${a.imagen}" alt="" onerror="this.style.display='none'">`
                            : `<i class="ri-image-line" style="color:#ccc;font-size:1.2rem;"></i>`}
                    </div>
                    <div class="sim-card-body">
                        <a href="/catalogo/productos/${encodeURIComponent(a.codigo)}" class="sim-card-name">${a.nombre}</a>
                        ${a.descripcion ? `<div class="sim-card-desc">${a.descripcion}</div>` : ''}
                        <button type="button" class="btn-sim-agregar btn-agregar-proyecto"
                                data-articulo-codigo="${a.codigo}"
                                data-articulo-nombre="${a.nombre.replace(/"/g, '&quot;')}">
                            + Agregar
                        </button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    document.querySelectorAll('.btn-similares-toggle').forEach(btn => {
        btn.addEventListener('click', async function () {
            const panelId = this.dataset.panel;
            const codigo  = this.dataset.codigo;
            const panel   = document.getElementById(panelId);
            const grid    = panel.querySelector('.similares-grid');
            const isOpen  = panel.classList.contains('open');

            if (isOpen) {
                panel.classList.remove('open');
                this.classList.remove('active');
                this.querySelector('.btn-sim-icon').className = 'ri-stack-line btn-sim-icon';
                this.querySelector('.btn-sim-text').textContent = 'Productos similares';
                return;
            }

            panel.classList.add('open');
            this.classList.add('active');
            this.querySelector('.btn-sim-icon').className = 'ri-close-line btn-sim-icon';
            this.querySelector('.btn-sim-text').textContent = 'Cerrar';

            if (panel.dataset.loaded === 'true') return;

            grid.innerHTML = '<div class="text-muted small py-2"><i class="ri-loader-4-line me-1"></i> Cargando…</div>';

            try {
                const res  = await fetch(`/catalogo/productos/${encodeURIComponent(codigo)}/similares`);
                const data = await res.json();
                panel.dataset.loaded = 'true';
                renderSimilares(grid, data);
            } catch {
                grid.innerHTML = '<p class="text-muted small mb-0">Error al cargar productos similares.</p>';
            }
        });
    });

    // ── Guardar comentario vía AJAX ──
    let commentTimers = {};
    document.querySelectorAll('.input-item-comment').forEach(ta => {
        ta.addEventListener('input', function () {
            const id = this.dataset.item;
            const status = document.querySelector(`.comment-status[data-item="${id}"]`);
            clearTimeout(commentTimers[id]);
            if (status) status.textContent = 'Escribiendo…';
            commentTimers[id] = setTimeout(async () => {
                const fd = new FormData();
                fd.append('comment', this.value);
                try {
                    const res = await fetch(`/secure/proyectos/item/${id}/comment`, { method: 'POST', body: fd });
                    const data = await res.json();
                    if (status) status.textContent = data.success ? 'Guardado ✓' : 'Error al guardar';
                    if (data.success) setTimeout(() => { if (status) status.textContent = ''; }, 2000);
                } catch {
                    if (status) status.textContent = 'Error al guardar';
                }
            }, 700);
        });
    });

})();
</script>
{% endblock %}
