{% extends 'base_catalogo.html.twig' %}

{% block title %}Mis Proyectos{% endblock %}

{% block breadcrumb %}
<ol class="breadcrumb mb-0">
    <li class="breadcrumb-item">
        <a href="{{ path('app_catalogo_index') }}">Catálogo</a>
    </li>
    <li class="breadcrumb-item active">Proyectos</li>
</ol>
{% endblock %}

{% block body %}
<div class="container-fluid">

    {# Header: título + botón crear #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Proyectos</h4>
        <button type="button"
                class="btn btn-warning fw-semibold"
                data-bs-toggle="modal"
                data-bs-target="#modalCrearProyecto">
            <i class="ri-add-line me-1"></i> Crear nuevo Proyecto
        </button>
    </div>

    {# Grid de proyectos #}
    {% if proyectos is empty %}
    <div class="text-center py-5">
        <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
             style="width:64px;height:64px;background:#2C3E50;">
            <i class="ri-folder-2-line text-white fs-3"></i>
        </div>
        <h5 class="text-muted mt-3">No tenés proyectos todavía</h5>
        <p class="text-muted small">Creá un proyecto para empezar a agregar productos del catálogo.</p>
        <button type="button"
                class="btn btn-warning fw-semibold mt-2"
                data-bs-toggle="modal"
                data-bs-target="#modalCrearProyecto">
            <i class="ri-add-line me-1"></i> Crear mi primer proyecto
        </button>
    </div>
    {% else %}
    <div class="row g-3">
        {% for proyecto in proyectos %}
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 d-flex flex-column">

                    {# Cabecera: icono + nombre + menú #}
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:40px;height:40px;background:#2C3E50;">
                                <i class="ri-folder-2-line text-white" style="font-size:1.1rem;"></i>
                            </div>
                            <h6 class="fw-semibold mb-0 line-clamp-2">{{ proyecto.nombre }}</h6>
                        </div>
                        <div class="dropdown ms-1 flex-shrink-0">
                            <button class="btn btn-sm btn-light border-0 px-2" data-bs-toggle="dropdown">
                                <i class="ri-more-2-fill"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_proyectos_show', {id: proyecto.id}) }}">
                                        <i class="ri-eye-line me-2"></i> Ver detalle
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_proyectos_editar', {id: proyecto.id}) }}">
                                        <i class="ri-edit-line me-2"></i> Editar
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <button class="dropdown-item text-danger btn-eliminar-proyecto"
                                            data-proyecto-id="{{ proyecto.id }}"
                                            data-proyecto-nombre="{{ proyecto.nombre|e('html_attr') }}">
                                        <i class="ri-delete-bin-line me-2"></i> Eliminar
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>

                    {# Descripción #}
                    {% if proyecto.descripcion %}
                    <p class="text-muted small mb-2 line-clamp-2">{{ proyecto.descripcion }}</p>
                    {% endif %}

                    {# Meta info #}
                    <p class="text-muted small mb-1">
                        Fecha de creación del proyecto: {{ proyecto.createdAt|date('d/m/Y') }}
                    </p>
                    <p class="text-muted small mb-3">
                        Cantidad de productos agregados: {{ proyecto.cantidadProductos }}
                    </p>

                    {# Acciones apiladas #}
                    <div class="mt-auto d-flex flex-column gap-2">
                        <button type="button" class="btn btn-sm fw-semibold w-100" disabled
                                style="background:var(--rkl-primary);color:#fff;border:none;">
                            Solicitar cotización
                        </button>
                        <a href="{{ path('app_proyectos_show', {id: proyecto.id}) }}"
                           class="btn btn-sm w-100"
                           style="border:1px solid var(--rkl-primary);color:var(--rkl-primary);background:transparent;">
                            Ver Proyecto
                        </a>
                    </div>

                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

</div>

{# Modal: Confirmar Eliminar #}
<div class="modal fade" id="modalEliminarProyecto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title text-danger">
                    <i class="ri-delete-bin-line me-2"></i>Eliminar Proyecto
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">¿Estás seguro que querés eliminar el proyecto <strong id="nombre-proyecto-eliminar"></strong>?</p>
                <p class="text-danger small">Esta acción no se puede deshacer y eliminará todos los productos del proyecto.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <form id="form-eliminar-proyecto" method="POST" class="d-inline">
                    <input type="hidden" name="_token" id="token-eliminar">
                    <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block extra_js %}
<script>
// Eliminar proyecto
document.querySelectorAll('.btn-eliminar-proyecto').forEach(btn => {
    btn.addEventListener('click', function () {
        const id     = this.dataset.proyectoId;
        const nombre = this.dataset.proyectoNombre;
        document.getElementById('nombre-proyecto-eliminar').textContent = `"${nombre}"`;
        document.getElementById('form-eliminar-proyecto').action = `/secure/proyectos/${id}/eliminar`;
        document.getElementById('token-eliminar').value = '{{ csrf_token("proyecto_eliminar_") }}' + id;
        new bootstrap.Modal(document.getElementById('modalEliminarProyecto')).show();
    });
});

// Recargar al crear proyecto desde el modal del base
document.addEventListener('rkl:proyecto-creado', function () {
    setTimeout(() => location.reload(), 800);
});
</script>
{% endblock %}
