<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Solicitud de presupuesto</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: #ebebeb;
            font-family: Arial, Helvetica, sans-serif;
            color: #1a1a1a;
        }
        .outer {
            background: #ebebeb;
            padding: 40px 20px;
        }
        .card {
            background: #ffffff;
            border-radius: 12px;
            max-width: 620px;
            margin: 0 auto;
            padding: 48px 48px 40px;
            box-shadow: 0 2px 12px rgba(0,0,0,.07);
        }
        .logo-wrap {
            text-align: center;
            margin-bottom: 40px;
        }
        .logo-wrap img {
            height: 44px;
        }
        .headline {
            font-size: 22px;
            font-weight: 400;
            line-height: 1.4;
            margin: 0 0 28px;
            color: #1a1a1a;
        }
        .headline strong {
            font-weight: 700;
        }
        /* ── Tabla ── */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 4px;
        }
        .items-table thead tr {
            background: #e8e8e8;
        }
        .items-table thead th {
            padding: 12px 16px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: #666;
            text-align: center;
        }
        .items-table thead th.col-producto {
            text-align: left;
        }
        .items-table tbody td {
            padding: 14px 16px;
            border-bottom: 1px solid #e8e8e8;
            font-size: 14px;
            vertical-align: middle;
        }
        .items-table tbody tr:last-child td {
            border-bottom: none;
        }
        .items-table tbody td.col-producto {
            font-weight: 600;
            color: #1a1a1a;
            border-right: 1px solid #e8e8e8;
        }
        .items-table tbody td.col-cantidad {
            text-align: center;
            font-weight: 700;
            font-size: 16px;
            color: #1a1a1a;
            border-right: 1px solid #e8e8e8;
        }
        .items-table tbody td.col-notas {
            text-align: left;
            color: #aaa;
            font-size: 13px;
        }
        /* outer border de la tabla */
        .table-wrap {
            border: 1px solid #e8e8e8;
            border-radius: 6px;
            overflow: hidden;
        }
    </style>
</head>
<body>
<div class="outer">
<div class="card">

    <div class="logo-wrap">
        <img src="https://racklatina.com/wp-content/uploads/2020/08/logo-racklatina.png"
             alt="Racklatina"
             onerror="this.src='https://racklatina.com/wp-content/uploads/2020/08/logo-racklatina-light.png'">
    </div>

    <p class="headline">
        <strong>{{ empresa_nombre ?? usuario_nombre }}</strong> ha solicitado presupuesto de los siguientes productos:
    </p>

    <div class="table-wrap">
        <table class="items-table">
            <thead>
                <tr>
                    <th class="col-producto">Producto</th>
                    <th>Cantidad</th>
                    <th>Notas</th>
                </tr>
            </thead>
            <tbody>
            {% for item in items %}
                <tr>
                    <td class="col-producto">{{ item.articulo.nombreDisplay }}</td>
                    <td class="col-cantidad">{{ item.cantidad }}</td>
                    <td class="col-notas">{{ item.comment ?? '' }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>
</div>
</body>
</html>
