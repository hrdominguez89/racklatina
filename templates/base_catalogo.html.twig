<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Catálogo{% endblock %} – Racklatina</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Catálogo de productos Racklatina">
    <link rel="shortcut icon" href="{{ asset('images/favicon.ico') }}">

    <!-- Bootstrap CSS -->
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <!-- Icons -->
    <link href="{{ asset('css/icons.min.css') }}" rel="stylesheet">
    <!-- App CSS (variables, colores Racklatina) -->
    <link href="{{ asset('css/app.min.css') }}" rel="stylesheet">
    <link href="{{ asset('css/custom.min.css') }}" rel="stylesheet">

    <style>
        :root {
            --rkl-primary: #ACA300;
            --rkl-primary-dark: #8a9b00;
        }
        body { background-color: #f5f5f5; }

        /* Navbar catálogo */
        .catalogo-navbar {
            background: #2C3E50;
            padding: 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 8px rgba(0,0,0,.2);
        }
        .catalogo-navbar-inner {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            height: 60px;
            gap: 1rem;
        }
        .catalogo-logo {
            flex-shrink: 0;
        }
        .catalogo-logo img {
            height: 32px;
        }
        .catalogo-search {
            flex: 1;
            max-width: 520px;
        }
        .catalogo-search .input-group {
            border-radius: 6px;
            overflow: hidden;
        }
        .catalogo-search input {
            border: none;
            font-size: .9rem;
        }
        .catalogo-search input:focus {
            box-shadow: none;
        }
        .catalogo-search .btn {
            background: var(--rkl-primary);
            border: none;
            color: #fff;
            padding: 0 1rem;
        }
        .catalogo-nav-links {
            display: flex;
            align-items: center;
            gap: .5rem;
            margin-left: auto;
            flex-shrink: 0;
        }
        .catalogo-nav-links a {
            color: rgba(255,255,255,.85);
            text-decoration: none;
            font-size: .875rem;
            padding: .375rem .75rem;
            border-radius: 4px;
            transition: background .15s;
            white-space: nowrap;
        }
        .catalogo-nav-links a:hover {
            background: rgba(255,255,255,.1);
            color: #fff;
        }
        .catalogo-nav-links .btn-login {
            background: var(--rkl-primary);
            color: #fff;
            font-weight: 600;
        }
        .catalogo-nav-links .btn-login:hover {
            background: var(--rkl-primary-dark);
        }
        .catalogo-user-name {
            color: rgba(255,255,255,.9);
            font-size: .875rem;
            font-weight: 500;
        }

        /* Subnavbar de categorías */
        .catalogo-subnav {
            background: #fff;
            border-bottom: 1px solid #e0e0e0;
        }
        .catalogo-subnav-inner {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            height: 44px;
            overflow-x: auto;
            scrollbar-width: none;
        }
        .catalogo-subnav-inner::-webkit-scrollbar { display: none; }
        .catalogo-subnav-inner a {
            color: #444;
            text-decoration: none;
            font-size: .875rem;
            white-space: nowrap;
            padding: .25rem 0;
            border-bottom: 2px solid transparent;
        }
        .catalogo-subnav-inner a:hover,
        .catalogo-subnav-inner a.active {
            color: var(--rkl-primary);
            border-bottom-color: var(--rkl-primary);
        }

        /* Contenido principal */
        .catalogo-main {
            max-width: 1400px;
            margin: 0 auto;
            padding: 1.5rem;
        }

        /* Cards */
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* Footer */
        .catalogo-footer {
            background: #2C3E50;
            color: rgba(255,255,255,.6);
            text-align: center;
            padding: 1.5rem;
            font-size: .8rem;
            margin-top: 3rem;
        }
        .catalogo-footer a { color: var(--rkl-primary); }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

<!-- NAVBAR PRINCIPAL -->
<nav class="catalogo-navbar">
    <div class="catalogo-navbar-inner">
        <!-- Logo -->
        <a href="{{ path('app_catalogo_index') }}" class="catalogo-logo">
            <img src="{{ asset('images/logo-racklatina-light.png') }}" alt="Racklatina" height="28"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='inline'">
            <span style="display:none;color:#fff;font-weight:700;font-size:1.1rem;letter-spacing:.5px;">RACKLATINA</span>
        </a>

        <!-- Buscador -->
        <form class="catalogo-search d-none d-md-block"
              action="{{ path('app_catalogo_lista') }}" method="GET">
            <div class="input-group">
                <input type="text" name="q" class="form-control"
                       placeholder="Buscá un producto..."
                       value="{{ app.request.query.get('q') ?? '' }}">
                <button type="submit" class="btn">
                    <i class="ri-search-line"></i>
                </button>
            </div>
        </form>

        <!-- Links derecha -->
        <div class="catalogo-nav-links">
            {% if app.user %}
                {# Usuario logueado #}
                <span class="catalogo-user-name d-none d-md-inline">
                    <i class="ri-user-line me-1"></i>{{ app.user.firstName }}
                </span>
                <a href="{{ path('app_proyectos_index') }}">
                    <i class="ri-folder-line me-1"></i>
                    Mis Proyectos
                </a>
                <a href="{{ path('app_logout') }}">
                    <i class="ri-logout-box-line me-1"></i>Salir
                </a>
            {% else %}
                {# No autenticado #}
                <a href="{{ path('app_login') }}" class="btn-login">
                    <i class="ri-login-box-line me-1"></i>Iniciar sesión
                </a>
            {% endif %}
        </div>
    </div>
</nav>

<!-- SUBNAVBAR: categorías como breadcrumb rápido -->
<div class="catalogo-subnav d-none d-md-block">
    <div class="catalogo-subnav-inner">
        <a href="{{ path('app_catalogo_index') }}"
           class="{{ app.request.attributes.get('_route') == 'app_catalogo_index' ? 'active' : '' }}">
            Inicio
        </a>
        <a href="{{ path('app_catalogo_lista') }}"
           class="{{ app.request.attributes.get('_route') == 'app_catalogo_lista' ? 'active' : '' }}">
            Todos los productos
        </a>
        {% block subnav_extra %}{% endblock %}
    </div>
</div>

<!-- Buscador mobile -->
<div class="d-md-none bg-light px-3 py-2 border-bottom">
    <form action="{{ path('app_catalogo_lista') }}" method="GET">
        <div class="input-group input-group-sm">
            <input type="text" name="q" class="form-control"
                   placeholder="Buscá un producto..."
                   value="{{ app.request.query.get('q') ?? '' }}">
            <button type="submit" class="btn btn-warning">
                <i class="ri-search-line"></i>
            </button>
        </div>
    </form>
</div>

<!-- FLASHES -->
{% for label, messages in app.flashes %}
    {% for message in messages %}
    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show mb-0 rounded-0" role="alert">
        <div style="max-width:1400px;margin:0 auto;padding:0 1.5rem;">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
    {% endfor %}
{% endfor %}

<!-- CONTENIDO PRINCIPAL -->
<main class="catalogo-main">
    {% block body %}{% endblock %}
</main>

<!-- FOOTER -->
<footer class="catalogo-footer">
    <p class="mb-1">
        &copy; {{ "now"|date("Y") }} <strong style="color:#fff;">Racklatina S.A.</strong> – Catálogo de Productos
    </p>
    {% if not app.user %}
    <p class="mb-0">
        <a href="{{ path('app_login') }}">Iniciar sesión</a> para acceder a todas las funcionalidades
    </p>
    {% endif %}
</footer>

<!-- JS -->
<script src="{{ asset('libs/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('js/app.js') }}"></script>

{% block javascripts %}{% endblock %}

</body>
</html>
