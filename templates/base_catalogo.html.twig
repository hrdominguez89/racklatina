<!DOCTYPE html>
<html lang="es" data-layout="vertical" data-topbar="light" data-sidebar="light" data-sidebar-size="sm" data-sidebar-image="none" data-preloader="disable" data-theme="default" data-bs-theme="light" data-theme-colors="default">

<head>
    <meta charset="UTF-8">
    <title>{% block title %}Catálogo{% endblock %} – Racklatina</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="Racklatina Catálogo" name="description"/>
    <link rel="shortcut icon" href="{{ asset('images/favicon.ico') }}">

    <!-- Layout config Js -->
    <script src="{{ asset('js/layout.js') }}"></script>
    <!-- RKL global namespace + toast — must be defined before any child template script -->
    <script>
    window.RKL = window.RKL || {};
    RKL.proyectoActivo = RKL.proyectoActivo || null;
    RKL.toast = function(mensaje, tipo, duracion) {
        tipo     = tipo     || 'success';
        duracion = duracion || 4000;
        var icons  = { success: 'ri-check-circle-line', danger: 'ri-error-warning-line', warning: 'ri-alert-line', info: 'ri-information-line' };
        var colors = { success: '#198754',              danger: '#dc3545',               warning: '#ffc107',       info: '#0dcaf0' };
        var icon  = icons[tipo]  || icons.info;
        var color = colors[tipo] || colors.info;
        var el = document.createElement('div');
        el.style.cssText = 'background:#fff;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,.12);border-left:4px solid '+color+';padding:.75rem 1rem;display:flex;align-items:flex-start;gap:.6rem;';
        el.innerHTML = '<i class="'+icon+' fs-5 mt-1 flex-shrink-0" style="color:'+color+'"></i>'
            + '<span class="flex-grow-1 small" style="color:#333;">'+mensaje+'</span>'
            + '<button style="background:none;border:none;padding:0;line-height:1;color:#aaa;cursor:pointer;font-size:1rem;" onclick="this.closest(\'div\').remove()">×</button>';
        var container = document.getElementById('rkl-toast-container');
        if (container) {
            container.appendChild(el);
            setTimeout(function() { el.style.opacity='0'; el.style.transition='opacity .3s'; setTimeout(function(){ el.remove(); }, 300); }, duracion);
        } else {
            // Fallback si el container aún no existe (muy raro)
            console.info('[RKL toast]', tipo, mensaje);
        }
    };
    </script>
    <!-- Bootstrap Css -->
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet" type="text/css"/>
    <!-- Icons Css -->
    <link href="{{ asset('css/icons.min.css') }}" rel="stylesheet" type="text/css"/>
    <!-- App Css -->
    <link href="{{ asset('css/app.min.css') }}" rel="stylesheet" type="text/css"/>
    <!-- custom Css -->
    <link href="{{ asset('css/custom.min.css') }}" rel="stylesheet" type="text/css"/>

    <style>
        :root {
            --rkl-primary: #ACA300;
            --rkl-primary-dark: #8a9b00;
        }

        /* Active nav */
        .navbar-menu .navbar-nav .nav-link.active,
        .navbar-menu .navbar-nav .nav-link.active:hover,
        .navbar-menu .navbar-nav .nav-link.active:focus {
            background-color: #3D4F5E !important;
            color: #ffffff !important;
        }
        .navbar-menu .navbar-nav .nav-link.active i {
            color: var(--rkl-primary) !important;
        }

        /* Forzar topbar blanco independientemente del tema */
        #page-topbar {
            background-color: #ffffff !important;
            border-bottom: 1px solid #e9ecef !important;
            box-shadow: 0 1px 4px rgba(0, 0, 0, .06) !important;
        }
        #topnav-hamburger-icon .hamburger-icon span {
            background-color: #555 !important;
        }
        #page-topbar .breadcrumb-item a { color: #666 !important; }
        #page-topbar .breadcrumb-item.active { color: #444 !important; }
        #page-topbar .breadcrumb-item + .breadcrumb-item::before { color: #bbb !important; }

        /* Header empresa badge */
        .header-empresa-btn {
            background: rgba(172, 163, 0, .1);
            color: #7a7300;
            border: 1px solid rgba(172, 163, 0, .3);
            border-radius: 20px;
            padding: .3rem .85rem;
            font-size: .8rem;
            font-weight: 500;
            white-space: nowrap;
            max-width: 240px;
            overflow: hidden;
            text-overflow: ellipsis;
            cursor: pointer;
            transition: background .15s;
        }
        .header-empresa-btn:hover {
            background: rgba(172, 163, 0, .18);
        }

        /* Header user section */
        .header-user-btn {
            background: none;
            border: none;
            padding: .25rem .5rem;
            border-radius: 8px;
            transition: background .15s;
        }
        .header-user-btn:hover {
            background: rgba(0, 0, 0, .05);
        }
        .header-user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #2C3E50;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: .8rem;
            font-weight: 700;
            flex-shrink: 0;
            letter-spacing: .5px;
        }
        .header-user-name {
            font-size: .85rem;
            font-weight: 600;
            color: #333;
            line-height: 1.25;
        }
        .header-user-meta {
            font-size: .72rem;
            color: #999;
            line-height: 1.25;
        }

        .main-content {
            padding-top: 0 !important;
        }
        .page-content {
            padding-top: 1.5rem !important;
        }

        /* Cards */
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body>
<div id="layout-wrapper">

    <!-- ===== HEADER ===== -->
    <header id="page-topbar">
        <div class="layout-width">
            <div class="navbar-header">

                <!-- Izquierda: hamburger + breadcrumb -->
                <div class="d-flex align-items-center">
                    <button type="button"
                            class="btn btn-sm px-3 fs-16 header-item vertical-menu-btn topnav-hamburger material-shadow-none"
                            id="topnav-hamburger-icon">
                        <span class="hamburger-icon">
                            <span></span>
                            <span></span>
                            <span></span>
                        </span>
                    </button>
                    <nav aria-label="breadcrumb" class="ms-2 d-none d-sm-flex align-items-center">
                        {% block breadcrumb %}
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_catalogo_index') }}">Catálogo</a>
                                </li>
                            </ol>
                        {% endblock %}
                    </nav>
                </div>

                <!-- Derecha: proyecto activo + empresa + usuario -->
                <div class="d-flex align-items-center gap-2">

                    {# Proyecto activo #}
                    {% if app.user is not null %}
                        {% set _proyectoActivo = proyecto_activo(app.user) %}
                        {% set _todosProyectos = proyectos_del_usuario(app.user) %}

                        {% if _proyectoActivo is not null %}
                        {# Hay proyecto activo: dropdown para cambiar o ver #}
                        <div class="dropdown d-none d-md-block">
                            <button type="button"
                                    class="btn btn-sm btn-warning d-flex align-items-center gap-1 position-relative"
                                    data-bs-toggle="dropdown" aria-expanded="false"
                                    title="Proyecto activo">
                                <i class="ri-folder-open-line"></i>
                                <span class="d-none d-lg-inline fw-semibold" style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    {{ _proyectoActivo.nombre }}
                                </span>
                                <span class="badge bg-dark text-white ms-1" style="font-size:.65rem;">
                                    {{ _proyectoActivo.cantidadProductos }}
                                </span>
                                <i class="ri-arrow-down-s-line"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" style="min-width:240px;">
                                <li>
                                    <a class="dropdown-item small fw-semibold" href="{{ path('app_proyectos_show', {id: _proyectoActivo.id}) }}">
                                        <i class="ri-eye-line me-1"></i> Ver proyecto actual
                                    </a>
                                </li>
                                {% if _todosProyectos|length > 1 %}
                                <li><hr class="dropdown-divider"></li>
                                <li><span class="dropdown-item-text text-muted small">Cambiar proyecto activo:</span></li>
                                {% for p in _todosProyectos %}
                                    {% if p.id != _proyectoActivo.id %}
                                    <li>
                                        <button type="button"
                                                class="dropdown-item small btn-set-proyecto-activo"
                                                data-proyecto-id="{{ p.id }}"
                                                data-proyecto-nombre="{{ p.nombre|e('html_attr') }}">
                                            <i class="ri-folder-line me-1 text-muted"></i>
                                            {{ p.nombre }}
                                            <span class="text-muted">({{ p.cantidadProductos }})</span>
                                        </button>
                                    </li>
                                    {% endif %}
                                {% endfor %}
                                {% endif %}
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item small" href="{{ path('app_proyectos_index') }}">
                                        <i class="ri-list-unordered me-1"></i> Todos mis proyectos
                                    </a>
                                </li>
                            </ul>
                        </div>
                        {% else %}
                        {# Sin proyecto activo: botón simple #}
                        <a href="{{ path('app_proyectos_index') }}"
                           class="btn btn-sm btn-outline-secondary d-none d-md-inline-flex align-items-center gap-1"
                           title="Mis Proyectos">
                            <i class="ri-folder-line"></i>
                            <span class="d-none d-lg-inline">Proyectos</span>
                            {% if _todosProyectos|length > 0 %}
                            <span class="badge bg-warning text-dark ms-1" style="font-size:.65rem;">
                                {{ _todosProyectos|length }}
                            </span>
                            {% endif %}
                        </a>
                        {% endif %}
                    {% endif %}

                    {# Empresa dropdown: muestra la activa, permite cambiar si hay más #}
                    {% if app.user is not null and app.user.userCustomers is not empty %}
                        {% set ucList = app.user.userCustomers %}
                        {% set activoCodigo = app.user.activeClienteCodigo %}
                        <div class="dropdown d-none d-md-block">
                            <button type="button"
                                    class="header-empresa-btn"
                                    {% if ucList|length > 1 %}data-bs-toggle="dropdown" aria-expanded="false"{% endif %}>
                                <i class="ri-building-line me-1"></i>
                                {{ cliente_razon_social(activoCodigo) }} ({{ activoCodigo }})
                                {% if ucList|length > 1 %}
                                    <i class="ri-arrow-down-s-line ms-1"></i>
                                {% endif %}
                            </button>
                            {% if ucList|length > 1 %}
                            <ul class="dropdown-menu dropdown-menu-end">
                                {% for uc in ucList %}
                                <li>
                                    <form method="POST" action="{{ path('app_catalogo_switch_empresa') }}">
                                        <input type="hidden" name="cliente_codigo" value="{{ uc.clienteCodigo }}">
                                        <button type="submit"
                                                class="dropdown-item small {% if uc.clienteCodigo == activoCodigo %}fw-semibold{% endif %}">
                                            <i class="ri-building-line me-1 text-muted"></i>
                                            {{ cliente_razon_social(uc.clienteCodigo) }}
                                            <span class="text-muted ms-1">({{ uc.clienteCodigo }})</span>
                                            {% if uc.clienteCodigo == activoCodigo %}
                                                <i class="ri-check-line ms-1 text-success"></i>
                                            {% endif %}
                                        </button>
                                    </form>
                                </li>
                                {% endfor %}
                            </ul>
                            {% endif %}
                        </div>
                    {% endif %}

                    {# Usuario dropdown #}
                    {% if app.user is not null %}
                        <div class="dropdown">
                            <button type="button"
                                    class="header-user-btn d-flex align-items-center gap-2"
                                    id="header-user-dropdown"
                                    data-bs-toggle="dropdown"
                                    aria-haspopup="true"
                                    aria-expanded="false">
                                <div class="header-user-avatar">
                                    {{- app.user.firstName|first|upper -}}{{- app.user.lastName|first|upper -}}
                                </div>
                                <div class="d-none d-xl-block text-start">
                                    <div class="header-user-name">
                                        {{ app.user.firstName }} {{ app.user.lastName }}
                                    </div>
                                    <div class="header-user-meta">
                                        {{ app.user.email }}
                                    </div>
                                </div>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end">
                                <a class="dropdown-item" href="{{ path('app_mi_perfil_controllador_edicion') }}">
                                    <i class="mdi mdi-account-circle fs-16 align-middle me-1"></i>
                                    Perfil
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="{{ path('app_logout') }}">
                                    <i class="mdi mdi-logout fs-16 align-middle me-1"></i>
                                    Cerrar sesión
                                </a>
                            </div>
                        </div>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-sm btn-warning fw-semibold">
                            Iniciar sesión
                        </a>
                    {% endif %}

                </div>
            </div>
        </div>
    </header>

    <!-- ===== SIDEBAR (misma estructura que menu.html.twig del portal) ===== -->
    <div class="app-menu navbar-menu">
        <div class="navbar-brand-box">
            <a href="{{ path('app_catalogo_index') }}" class="logo logo-dark">
                <span class="logo-sm">
                    <img src="{{ asset('images/logo-sm.png') }}" alt="" height="22">
                </span>
                <span class="logo-lg">
                    <img src="{{ asset('images/logo-racklatina-light.png') }}" alt="" height="17">
                </span>
            </a>
            <a href="{{ path('app_catalogo_index') }}" class="logo logo-light">
                <span class="logo-sm">
                    <img src="{{ asset('images/logo-sm.png') }}" alt="" height="22">
                </span>
                <span class="logo-lg">
                    <img src="{{ asset('images/logo-racklatina-light.png') }}" alt="" height="17">
                </span>
            </a>
            <button type="button"
                    class="btn btn-sm p-0 fs-20 header-item float-end btn-vertical-sm-hover"
                    id="vertical-hover">
                <i class="ri-record-circle-line"></i>
            </button>
        </div>
        <div id="scrollbar">
            <div class="container-fluid">
                <div id="two-column-menu"></div>
                <ul class="navbar-nav" id="navbar-nav">
                    <li class="menu-title">
                        <span data-key="t-menu">Menu</span>
                    </li>
                    {{ include('menu_catalogo.html.twig') }}
                </ul>
            </div>
        </div>
        <div class="sidebar-background"></div>
    </div>

    <div class="vertical-overlay"></div>

    <!-- ===== CONTENIDO ===== -->
    <div class="main-content">
        <div class="page-content">

            {# Flashes #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>
    </div>

</div>

{# Toast container global #}
<div id="rkl-toast-container"
     style="position:fixed;top:72px;right:1rem;z-index:9999;display:flex;flex-direction:column;gap:.5rem;min-width:280px;max-width:360px;">
</div>

<!-- JS -->
<script src="{{ asset('libs/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('libs/simplebar/simplebar.min.js') }}"></script>
<script src="{{ asset('libs/node-waves/waves.min.js') }}"></script>
<script src="{{ asset('libs/feather-icons/feather.min.js') }}"></script>
<script src="{{ asset('js/app.js') }}"></script>

<script>
{% if app.user is not null %}
{% set _pa = proyecto_activo(app.user) %}
RKL.proyectoActivo = {{ _pa is not null ? '{id:' ~ _pa.id ~ ',nombre:' ~ _pa.nombre|json_encode ~ '}' : 'null' }};
{% else %}
RKL.proyectoActivo = null;
{% endif %}

// Cambiar proyecto activo desde el header dropdown
document.addEventListener('click', function(e) {
    const btn = e.target.closest('.btn-set-proyecto-activo');
    if (!btn) return;
    const id = btn.dataset.proyectoId;
    const nombre = btn.dataset.proyectoNombre;
    fetch(`/secure/proyectos/${id}/set-activo`, { method: 'POST' })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                RKL.proyectoActivo = { id: parseInt(id), nombre: nombre };
                RKL.toast(`Proyecto activo: <strong>${nombre}</strong>`, 'success');
                setTimeout(() => location.reload(), 800);
            }
        })
        .catch(() => RKL.toast('Error al cambiar proyecto', 'danger'));
});
</script>

<style>
@keyframes rklSlideIn {
    from { transform: translateX(20px); opacity: 0; }
    to   { transform: translateX(0);    opacity: 1; }
}
</style>

{% block extra_js %}{% endblock %}
</body>
</html>
